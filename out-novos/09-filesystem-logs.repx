<?xml version="1.0" encoding="utf-8"?>
<Report SchemaVersion="1.0" Name="Auditoria de Arquivos (FileSystem)">
  <PageSetup Orientation="Landscape" Margins="591,591,591,591" Columns="1" ColumnSpacing="0">
    <Paper Name="A4" Width="8268" Height="11693" />
  </PageSetup>
  <Parameters>
    <Parameter Name="Root" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" Required="true" AllowMultiple="false" Prompt="Diretório raiz">
      <DefaultValue Value="C:\Users\ander\source\repos\afernandes\Omni\OmniReport\samples\Reporting.Samples.CodeFirst\bin\Debug\net10.0\" />
    </Parameter>
  </Parameters>
  <DataSources>
    <DataSource Name="Files" FilterExpression="Fields.Extension != '.pdb' &amp;&amp; Fields.Extension != '.cache'">
      <Fields>
        <Field Name="Id" Type="System.Int32, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="ParentId" Type="System.Int32, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Name" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="FullName" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Extension" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="IsDirectory" Type="System.Boolean, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Size" Type="System.Int64, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="CreationTime" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="LastAccessTime" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="LastWriteTime" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
      </Fields>
      <SortExpressions>
        <Sort Expression="Fields.Size" Direction="Descending" />
      </SortExpressions>
    </DataSource>
  </DataSources>
  <ReportHeader Kind="ReportHeader" Height="945" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <TextBox Id="d4b46d4dc9eb4988a6b0fabb1e7a2139" Bounds="0,0,10512,472" Visible="true">
        <Style HorizontalAlignment="Center" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="16" Style="Bold" />
        </Style>
        <Expression>Auditoria de Arquivos · Fonte FileSystem</Expression>
      </TextBox>
      <TextBox Id="2381f9f7340543919b0acb59287014d5" Bounds="0,551,10512,236" Visible="true">
        <Style HorizontalAlignment="Center" VerticalAlignment="Top" WordWrap="true">
          <ForeColor>#808080</ForeColor>
        </Style>
        <Expression>Diretório: {Parameters.Root}</Expression>
      </TextBox>
      <Line Id="0b28c37d55a347a5b6bbef6be650c3ae" Bounds="0,866,10512,0" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Direction>Horizontal</Direction>
        <Pen Style="Solid" Thickness="7" Color="#000000" />
      </Line>
    </Elements>
  </ReportHeader>
  <PageHeader Kind="PageHeader" Height="315" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <Label Id="53f6a570711443d7b3b56e4e3ad292d1" Bounds="0,0,5512,236" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Arquivo</Text>
      </Label>
      <Label Id="4d98a2348ece4d2eaabd889f00699076" Bounds="5591,0,787,236" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Extensão</Text>
      </Label>
      <Label Id="b73b44dfc07d4e06b4aa8244ab6b6a8b" Bounds="6457,0,1181,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Tamanho (B)</Text>
      </Label>
      <Label Id="29793b54689c46c79cfd82ecead36a7d" Bounds="7717,0,1575,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Modificado em</Text>
      </Label>
      <Label Id="b7719eb8b06541adab5e17a4391c252d" Bounds="9370,0,1142,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Criado em</Text>
      </Label>
      <Line Id="41c2bf18c2b44e978a497308472d7e06" Bounds="0,236,10512,0" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Direction>Horizontal</Direction>
        <Pen Style="Solid" Thickness="3" Color="#000000" />
      </Line>
    </Elements>
  </PageHeader>
  <Groups>
    <Group Name="PorExtensao" GroupExpression="Fields.Extension" KeepTogether="false" NewPageBefore="false" NewPageAfter="false" RepeatHeaderOnNewPage="false" Visible="true">
      <Header Kind="GroupHeader" Height="315" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
        <Elements>
          <TextBox Id="76434493ff8b427e91d8d0ecc45a0587" Bounds="0,39,10512,236" Visible="true">
            <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
              <Font Family="Arial" Size="10" Style="Bold" />
              <ForeColor>#C2410C</ForeColor>
            </Style>
            <Expression>Extensão: {Fields.Extension}</Expression>
          </TextBox>
        </Elements>
      </Header>
    </Group>
  </Groups>
  <Detail Height="197" Visible="true" CanGrow="false" CanShrink="false" NoRowsMessage="Nenhum arquivo encontrado no diretório.">
    <Elements>
      <TextBox Id="dd6c3e8b0fd2459e9ea99a82e5c20210" Bounds="0,0,5512,197" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="8" Style="Regular" />
        </Style>
        <Expression>{Fields.Name}</Expression>
      </TextBox>
      <TextBox Id="fc977eb7ca3c41138efd2dbdbe4265f5" Bounds="5591,0,787,197" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="8" Style="Regular" />
        </Style>
        <Expression>{Fields.Extension}</Expression>
      </TextBox>
      <TextBox Id="524e57a56a9c47b4a7256de5a0b9cf79" Bounds="6457,0,1181,197" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="8" Style="Regular" />
        </Style>
        <Expression>{Fields.Size:N0}</Expression>
      </TextBox>
      <TextBox Id="229aae398080443196f047587a9f4ace" Bounds="7717,0,1575,197" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="8" Style="Regular" />
        </Style>
        <Expression>{Fields.LastWriteTime:dd/MM/yyyy HH:mm}</Expression>
      </TextBox>
      <TextBox Id="cb697a9f6d2d4e8195e57dbfc0b66ba7" Bounds="9370,0,1142,197" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="8" Style="Regular" />
        </Style>
        <Expression>{Fields.CreationTime:dd/MM/yyyy HH:mm}</Expression>
      </TextBox>
    </Elements>
  </Detail>
  <PageFooter Kind="PageFooter" Height="236" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <TextBox Id="1f4d4638288543b3b1f2e4740aca13b5" Bounds="0,0,10512,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <ForeColor>#808080</ForeColor>
        </Style>
        <Expression>OmniReport · Página {Page.Number} de {Page.Total}</Expression>
      </TextBox>
    </Elements>
  </PageFooter>
  <ReportFooter Kind="ReportFooter" Height="472" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <Line Id="64071e90f28c48f1af6115d4452452c6" Bounds="0,0,10512,0" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Direction>Horizontal</Direction>
        <Pen Style="Solid" Thickness="7" Color="#000000" />
      </Line>
      <TextBox Id="950ac681e33342a3acdac4eb0d0dc686" Bounds="0,79,10512,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Expression>Arquivos: {Count(Fields.Name)} · Tamanho total: {Sum(Fields.Size):N0} bytes</Expression>
      </TextBox>
    </Elements>
  </ReportFooter>
</Report>