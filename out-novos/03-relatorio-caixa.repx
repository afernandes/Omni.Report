          </Rectangle>
          <TextBox Id="6a6e6e41698c4ebeabe5c45ec62a1a5a" Bounds="79,79,6693,197" Visible="true">
            <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
              <Font Family="Arial" Size="10" Style="Bold" />
              <ForeColor>#C2410C</ForeColor>
            </Style>
            <Expression>Forma de pagamento: {Fields.FormaPagamento}</Expression>
          </TextBox>
        </Elements>
      </Header>
      <Footer Kind="GroupFooter" Height="315" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
        <Elements>
          <Line Id="2dd2556108b246b7adab92d269863d1d" Bounds="0,0,6693,0" Visible="true">
            <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
            <Direction>Horizontal</Direction>
