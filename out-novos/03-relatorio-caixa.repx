          </Line>
          <TextBox Id="5f273d41f0bb42f69ee0a2d6f30032fb" Bounds="0,79,6693,197" Visible="true">
            <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
              <Font Family="Arial" Size="10" Style="Bold" />
            </Style>
            <Expression>Subtotal: {Sum(Fields.Valor, 'Group'):C} · {Count(Fields.Valor, 'Group')} movimento(s)</Expression>
          </TextBox>
        </Elements>
      </Footer>
    </Group>
  </Groups>
  <Detail Height="236" Visible="true" CanGrow="false" CanShrink="false">
