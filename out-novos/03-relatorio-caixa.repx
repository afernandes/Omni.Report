<?xml version="1.0" encoding="utf-8"?>
<Report SchemaVersion="1.0" Name="Movimento de Caixa">
  <PageSetup Orientation="Portrait" Margins="787,787,787,787" Columns="1" ColumnSpacing="0">
    <Paper Name="A4" Width="8268" Height="11693" />
  </PageSetup>
  <Parameters>
    <Parameter Name="Data" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" Required="true" AllowMultiple="false" Prompt="Data do movimento">
      <DefaultValue Value="05/23/2026 00:00:00" />
    </Parameter>
  </Parameters>
  <DataSources>
    <DataSource Name="Caixa">
      <Fields>
        <Field Name="Data" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Documento" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="FormaPagamento" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Valor" Type="System.Decimal, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
      </Fields>
    </DataSource>
  </DataSources>
  <ReportHeader Kind="ReportHeader" Height="984" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <TextBox Id="58792f0aa0f24f898c65ea36450b5432" Bounds="0,0,6693,472" Visible="true">
        <Style HorizontalAlignment="Center" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="16" Style="Bold" />
        </Style>
