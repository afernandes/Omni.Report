      <Line Id="6939a54d96b342e5b24fdc93296afd19" Bounds="0,866,6693,0" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Direction>Horizontal</Direction>
        <Pen Style="Solid" Thickness="7" Color="#000000" />
      </Line>
    </Elements>
  </ReportHeader>
  <Groups>
    <Group Name="PorFormaPagamento" GroupExpression="Fields.FormaPagamento" KeepTogether="false" NewPageBefore="false" NewPageAfter="false" RepeatHeaderOnNewPage="false" Visible="true">
      <Header Kind="GroupHeader" Height="394" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
        <Elements>
          <Rectangle Id="8d4fe7c5435b47d48a9e8a5e53263fe4" Bounds="0,39,6693,276" Visible="true">
            <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
