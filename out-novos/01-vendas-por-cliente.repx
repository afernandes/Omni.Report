<?xml version="1.0" encoding="utf-8"?>
<Report SchemaVersion="1.0" Name="Vendas por Cliente">
  <PageSetup Orientation="Portrait" Margins="787,787,787,787" Columns="1" ColumnSpacing="0">
    <Paper Name="A4" Width="8268" Height="11693" />
  </PageSetup>
  <Parameters>
    <Parameter Name="DataInicio" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" Required="true" AllowMultiple="false" Prompt="Data inicial">
      <DefaultValue Value="05/01/2026 00:00:00" />
    </Parameter>
    <Parameter Name="DataFim" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" Required="true" AllowMultiple="false" Prompt="Data final">
      <DefaultValue Value="05/31/2026 00:00:00" />
    </Parameter>
  </Parameters>
  <DataSources>
    <DataSource Name="Vendas">
      <Fields>
        <Field Name="Cliente" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Produto" Type="System.String, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Quantidade" Type="System.Int32, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="PrecoUnitario" Type="System.Decimal, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="DataVenda" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
        <Field Name="Total" Type="System.Decimal, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" />
      </Fields>
    </DataSource>
  </DataSources>
  <ReportHeader Kind="ReportHeader" Height="1575" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <TextBox Id="bf603485299d48b29026f50cdd61b065" Bounds="0,0,6693,472" Visible="true">
        <Style HorizontalAlignment="Center" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="16" Style="Bold" />
        </Style>
        <Expression>Relatório de Vendas</Expression>
      </TextBox>
      <TextBox Id="95e15c74c3ce4eab8fea06ff987fc5ff" Bounds="0,551,6693,315" Visible="true">
        <Style HorizontalAlignment="Center" VerticalAlignment="Top" WordWrap="true" />
        <Expression>Período: {Parameters.DataInicio:dd/MM/yyyy} a {Parameters.DataFim:dd/MM/yyyy}</Expression>
      </TextBox>
      <Line Id="58f015be8a284043957ca0c91eaa3ac8" Bounds="0,866,6693,0" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Direction>Horizontal</Direction>
        <Pen Style="Solid" Thickness="7" Color="#000000" />
      </Line>
    </Elements>
  </ReportHeader>
  <PageHeader Kind="PageHeader" Height="315" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <Label Id="e0f739a3a72541479b89f9466e1450a4" Bounds="0,0,3228,236" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Produto</Text>
      </Label>
      <Label Id="ff34e21053c54f08bc48c9ec6dffcd8e" Bounds="3228,0,787,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Qtde</Text>
      </Label>
      <Label Id="eb73aeda61b64c449b77356d2186791c" Bounds="4094,0,1181,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Preço Unitário</Text>
      </Label>
      <Label Id="e2aa532f25784acf8b93d8d64ffd18a6" Bounds="5354,0,1339,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="10" Style="Bold" />
        </Style>
        <Text>Total</Text>
      </Label>
      <Line Id="e47af247a4a44420977f6a6e17a0d2aa" Bounds="0,236,6693,0" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Direction>Horizontal</Direction>
        <Pen Style="Solid" Thickness="3" Color="#000000" />
      </Line>
    </Elements>
  </PageHeader>
  <Groups>
    <Group Name="PorCliente" GroupExpression="Fields.Cliente" KeepTogether="false" NewPageBefore="false" NewPageAfter="false" RepeatHeaderOnNewPage="false" Visible="true">
      <Header Kind="GroupHeader" Height="394" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
        <Elements>
          <TextBox Id="e3afce9f81eb4e19b21e55e120d6ad03" Bounds="0,79,6693,236" Visible="true">
            <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true">
              <Font Family="Arial" Size="11" Style="Bold" />
              <ForeColor>#C2410C</ForeColor>
            </Style>
            <Expression>Cliente: {Fields.Cliente}</Expression>
          </TextBox>
        </Elements>
      </Header>
      <Footer Kind="GroupFooter" Height="315" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
        <Elements>
          <Line Id="f5f984cffde54f9680442adac0eb6c6b" Bounds="0,0,6693,0" Visible="true">
            <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
            <Direction>Horizontal</Direction>
            <Pen Style="Solid" Thickness="3" Color="#000000" />
          </Line>
          <TextBox Id="0c25a4a7ee0c47289a7765a1a49d3eb9" Bounds="0,39,6693,236" Visible="true">
            <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
              <Font Family="Arial" Size="10" Style="Bold" />
            </Style>
            <Expression>Subtotal {Fields.Cliente}: {Sum(Fields.Total, 'Group'):C}</Expression>
          </TextBox>
        </Elements>
      </Footer>
    </Group>
  </Groups>
  <Detail Height="236" Visible="true" CanGrow="false" CanShrink="false">
    <Elements>
      <TextBox Id="1ca8e950c6fe4450a31b8a2440675d28" Bounds="0,0,3150,236" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Expression>{Fields.Produto}</Expression>
      </TextBox>
      <TextBox Id="a4ca21b2a41b4a46859624216dbc3b6b" Bounds="3228,0,787,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true" />
        <Expression>{Fields.Quantidade:N2}</Expression>
      </TextBox>
      <TextBox Id="6837f05be32343469073f087453035db" Bounds="4094,0,1181,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true" />
        <Expression>{Fields.PrecoUnitario:C}</Expression>
      </TextBox>
      <TextBox Id="7113f7661a72405d94b209ae79d4828c" Bounds="5354,0,1339,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true" />
        <Expression>{Fields.Total:C}</Expression>
      </TextBox>
    </Elements>
  </Detail>
  <PageFooter Kind="PageFooter" Height="315" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <TextBox Id="dadcacd404d94524be02fab0b2260ffe" Bounds="0,39,6693,236" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <ForeColor>#808080</ForeColor>
        </Style>
        <Expression>Página {Page.Number} de {Page.Total}</Expression>
      </TextBox>
    </Elements>
  </PageFooter>
  <ReportFooter Kind="ReportFooter" Height="591" Visible="true" PrintOnFirstPage="true" PrintOnLastPage="true">
    <Elements>
      <Line Id="558d77aad312499ea412d907d9ccded0" Bounds="0,0,6693,0" Visible="true">
        <Style HorizontalAlignment="Left" VerticalAlignment="Top" WordWrap="true" />
        <Direction>Horizontal</Direction>
        <Pen Style="Solid" Thickness="7" Color="#000000" />
      </Line>
      <TextBox Id="4ccb7c63230c4ada870730b5256a5e14" Bounds="0,79,6693,394" Visible="true">
        <Style HorizontalAlignment="Right" VerticalAlignment="Top" WordWrap="true">
          <Font Family="Arial" Size="11" Style="Bold" />
        </Style>
        <Expression>Total geral: {Sum(Fields.Total):C}</Expression>
      </TextBox>
    </Elements>
  </ReportFooter>
</Report>