<?xml version="1.0" encoding="utf-8"?>
<Report SchemaVersion="1.0" Name="Vendas SQLite (ADO.NET)">
  <PageSetup Orientation="Portrait" Margins="709,709,709,709" Columns="1" ColumnSpacing="0">
