  <Parameters>
    <Parameter Name="DataInicio" Type="System.DateTime, System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e" Required="true" AllowMultiple="false" Prompt="Data inicial">
      <DefaultValue Value="05/01/2026 00:00:00" />
