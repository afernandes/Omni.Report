<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Restore reprodutível: apenas nuget.org (clear remove fontes herdadas da máquina/CI).
       Importante porque publicamos no GitHub Packages — sem isto, um feed do GitHub
       configurado no ambiente poderia interferir no restore. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
