    private static string SanitizeName(string label)
    {
        var sb = new System.Text.StringBuilder(label.Length);
        foreach (var c in label) if (char.IsLetterOrDigit(c)) sb.Append(c);
        return sb.Length > 0 ? sb.ToString() : "Field";
    }

