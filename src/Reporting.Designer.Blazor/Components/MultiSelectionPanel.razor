@namespace Reporting.Designer.Blazor.Components
@using System.Globalization
@implements IDisposable

@* Property panel shown when the selection has 2+ elements. Mirrors Visual Studio /
   WinForms designer behavior:
   • Common-value fields show the value, editable.
   • Mixed-value fields show "—" placeholder, still editable.
   • Editing any field writes to EVERY selected element.
   • Type-specific sections (Font / Color) only render if at least one selected element
     supports the property. *@

<div style="display:flex;align-items:center;gap:8px;height:34px;padding:0 12px;border-bottom:1px solid var(--border);background:var(--bg-surface);">
    <Icon Name="layers" Size="16" CssClass="icon icon-16" />
    <div style="flex:1;min-width:0;">
        <div style="font-size:12px;font-weight:600;color:var(--text-primary);">
            @Selection.Count elementos selecionados
        </div>
        <div style="font-size:10px;color:var(--text-tertiary);font-family:var(--font-mono);">
            @KindsBreakdown()
        </div>
    </div>
    <span style="font-family:var(--font-mono);font-size:10px;color:var(--accent);padding:1px 5px;border:1px solid var(--accent);border-radius:2px;">@Selection.Count sel.</span>
</div>

<div class="prop-section">
    <div class="prop-section-head">
        <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
        <span>Layout</span><span class="count">4</span>
    </div>
    @MixedRow("X", Selection.Select(e => e.X.ToMm()).ToArray(), v => Apply(e => e.X = Unit.FromMm(v)))
    @MixedRow("Y", Selection.Select(e => e.Y.ToMm()).ToArray(), v => Apply(e => e.Y = Unit.FromMm(v)))
    @MixedRow("Width",  Selection.Select(e => e.Width.ToMm()).ToArray(),  v => Apply(e => e.Width  = Unit.FromMm(v)))
    @MixedRow("Height", Selection.Select(e => e.Height.ToMm()).ToArray(), v => Apply(e => e.Height = Unit.FromMm(v)))
</div>

@if (Selection.Any(HasTextContent))
{
    <div class="prop-section">
        <div class="prop-section-head">
            <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
            <span>Aparência</span><span class="count">4</span>
        </div>

        <div class="prop-row">
            <div class="p-label">Fonte</div>
            <div class="p-editor">
                <input value="@CommonValue(e => e.FontFamily, "—")"
                       placeholder="—"
                       @onchange="@(e => Apply(el => { if (HasTextContent(el)) el.FontFamily = e.Value?.ToString() ?? el.FontFamily; }))"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                <span style="color:var(--text-tertiary);">·</span>
                <input value="@CommonValue(e => e.FontSize.ToString("F1", CultureInfo.InvariantCulture), "—")" type="text"
                       placeholder="—"
                       @onchange="@(e => SetFontSize(e.Value?.ToString()))"
                       style="width:46px;font-family:var(--font-mono);font-size:11.5px;text-align:right;" />
                <span class="p-unit">pt</span>
            </div>
        </div>

        <div class="prop-row">
            <div class="p-label">Estilo</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(TriState(e => e.IsBold)        == TriBool.AllOn ? "is-on" : TriState(e => e.IsBold)        == TriBool.Mixed ? "is-mixed" : null)" type="button" @onclick="@(() => ToggleBool(e => e.IsBold,        (e, v) => e.IsBold = v))">B</button>
                    <button class="@(TriState(e => e.IsItalic)      == TriBool.AllOn ? "is-on" : TriState(e => e.IsItalic)      == TriBool.Mixed ? "is-mixed" : null)" type="button" @onclick="@(() => ToggleBool(e => e.IsItalic,      (e, v) => e.IsItalic = v))">I</button>
                    <button class="@(TriState(e => e.IsUnderline)   == TriBool.AllOn ? "is-on" : TriState(e => e.IsUnderline)   == TriBool.Mixed ? "is-mixed" : null)" type="button" @onclick="@(() => ToggleBool(e => e.IsUnderline,   (e, v) => e.IsUnderline = v))">U</button>
                    <button class="@(TriState(e => e.IsStrikethrough) == TriBool.AllOn ? "is-on" : TriState(e => e.IsStrikethrough) == TriBool.Mixed ? "is-mixed" : null)" type="button" @onclick="@(() => ToggleBool(e => e.IsStrikethrough, (e, v) => e.IsStrikethrough = v))">S</button>
                </span>
            </div>
        </div>

        <div class="prop-row">
            <div class="p-label">Cor</div>
            <div class="p-editor">
                @{
                    var fore = CommonColor(e => e.ForeColor);
                }
                <span class="color-swatch" style="@(fore is null ? "background:repeating-linear-gradient(45deg,#bbb 0 4px,#eee 4px 8px);" : $"background:{ColorHex(fore.Value)};")"></span>
                <input type="color" value="@(fore is null ? "#000000" : ColorHex(fore.Value))"
                       @onchange="@(e => SetForeColor(e.Value?.ToString()))"
                       style="width:36px;height:16px;cursor:pointer;" />
                <span class="mono" style="font-size:11.5px;">@(fore is null ? "Misturado" : ColorHex(fore.Value))</span>
            </div>
        </div>

        <div class="prop-row">
            <div class="p-label">Alinhamento H</div>
            <div class="p-editor">
                <span class="align-row" aria-label="Horizontal">
                    @{ var hAlign = CommonValue<HorizontalAlignment>(e => e.HorizontalAlignment, null); }
                    <button class="@(hAlign == HorizontalAlignment.Left   ? "is-on" : null)" type="button"
                            @onclick="@(() => Apply(el => { if (HasTextContent(el)) el.HorizontalAlignment = HorizontalAlignment.Left; }))">
                        <Icon Name="align-left" Size="12" CssClass="icon icon-12" />
                    </button>
                    <button class="@(hAlign == HorizontalAlignment.Center ? "is-on" : null)" type="button"
                            @onclick="@(() => Apply(el => { if (HasTextContent(el)) el.HorizontalAlignment = HorizontalAlignment.Center; }))">
                        <Icon Name="align-center" Size="12" CssClass="icon icon-12" />
                    </button>
                    <button class="@(hAlign == HorizontalAlignment.Right  ? "is-on" : null)" type="button"
                            @onclick="@(() => Apply(el => { if (HasTextContent(el)) el.HorizontalAlignment = HorizontalAlignment.Right; }))">
                        <Icon Name="align-right" Size="12" CssClass="icon icon-12" />
                    </button>
                </span>
            </div>
        </div>
    </div>
}

<div class="prop-section">
    <div class="prop-section-head">
        <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
        <span>Comportamento</span><span class="count">2</span>
    </div>
    <div class="prop-row">
        <div class="p-label">Bloqueado</div>
        <div class="p-editor">
            <span class="editor-toggle">
                <button class="@(TriState(e => e.IsLocked) == TriBool.AllOn ? "is-on" : TriState(e => e.IsLocked) == TriBool.Mixed ? "is-mixed" : null)"
                        type="button"
                        @onclick="@(() => ToggleBool(e => e.IsLocked, (e, v) => e.IsLocked = v))">
                    @(TriState(e => e.IsLocked) == TriBool.AllOn ? "Sim" : TriState(e => e.IsLocked) == TriBool.Mixed ? "—" : "Não")
                </button>
            </span>
        </div>
    </div>
    <div class="prop-row">
        <div class="p-label">Visível</div>
        <div class="p-editor">
            <span class="editor-toggle">
                <button class="@(TriState(e => e.IsVisible) == TriBool.AllOn ? "is-on" : TriState(e => e.IsVisible) == TriBool.Mixed ? "is-mixed" : null)"
                        type="button"
                        @onclick="@(() => ToggleBool(e => e.IsVisible, (e, v) => e.IsVisible = v))">
                    @(TriState(e => e.IsVisible) == TriBool.AllOn ? "Sim" : TriState(e => e.IsVisible) == TriBool.Mixed ? "—" : "Não")
                </button>
            </span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ElementViewModel> Selection { get; set; } = [];

    private readonly HashSet<ElementViewModel> _subscribed = new();

    protected override void OnParametersSet()
    {
        // Subscribe/unsubscribe per-element so any external mutation re-renders the panel.
        var current = new HashSet<ElementViewModel>(Selection);
        foreach (var stale in _subscribed.Except(current).ToArray())
        {
            stale.Changed -= StateHasChanged;
            _subscribed.Remove(stale);
        }
        foreach (var added in current.Except(_subscribed).ToArray())
        {
            added.Changed += StateHasChanged;
            _subscribed.Add(added);
        }
    }

    public void Dispose()
    {
        foreach (var e in _subscribed) e.Changed -= StateHasChanged;
        _subscribed.Clear();
    }

    // ── Helpers ─────────────────────────────────────────────────────────────────
    private void Apply(Action<ElementViewModel> mutate)
    {
        foreach (var el in Selection) mutate(el);
    }

    private string CommonValue(Func<ElementViewModel, string?> selector, string fallback)
    {
        if (Selection.Count == 0) return fallback;
        var first = selector(Selection[0]);
        foreach (var e in Selection.Skip(1)) if (!Equals(selector(e), first)) return fallback;
        return first ?? fallback;
    }

    private T? CommonValue<T>(Func<ElementViewModel, T> selector, T? fallback) where T : struct
    {
        if (Selection.Count == 0) return fallback;
        var first = selector(Selection[0]);
        foreach (var e in Selection.Skip(1)) if (!EqualityComparer<T>.Default.Equals(selector(e), first)) return fallback;
        return first;
    }

    private Color? CommonColor(Func<ElementViewModel, Color> selector)
    {
        if (Selection.Count == 0) return null;
        var first = selector(Selection[0]);
        foreach (var e in Selection.Skip(1)) if (!selector(e).Equals(first)) return null;
        return first;
    }

    private enum TriBool { AllOff, AllOn, Mixed }

    private TriBool TriState(Func<ElementViewModel, bool> selector)
    {
        if (Selection.Count == 0) return TriBool.AllOff;
        var any = false; var all = true;
        foreach (var e in Selection)
        {
            var v = selector(e);
            any |= v; all &= v;
        }
        return all ? TriBool.AllOn : any ? TriBool.Mixed : TriBool.AllOff;
    }

    private void ToggleBool(Func<ElementViewModel, bool> getter, Action<ElementViewModel, bool> setter)
    {
        // If mixed or all-off → flip to all-on. If all-on → flip to all-off. Matches the
        // VS WinForms behaviour where clicking a "mixed" toggle unifies upward.
        var target = TriState(getter) != TriBool.AllOn;
        foreach (var e in Selection) setter(e, target);
    }

    private RenderFragment MixedRow(string label, double[] values, Action<double> setter) => builder =>
    {
        var first = values.Length > 0 ? values[0] : 0;
        var same = values.All(v => Math.Abs(v - first) < 0.001);
        var display = same ? first.ToString("F1", CultureInfo.InvariantCulture) : "";

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "prop-row");
        {
            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", "p-label");
            builder.AddContent(4, label);
            builder.CloseElement();

            builder.OpenElement(5, "div");
            builder.AddAttribute(6, "class", "p-editor");
            {
                builder.OpenElement(7, "input");
                builder.AddAttribute(8, "type", "number");
                builder.AddAttribute(9, "step", "0.1");
                builder.AddAttribute(10, "value", display);
                builder.AddAttribute(11, "placeholder", same ? "" : "—");
                builder.AddAttribute(12, "style", "flex:1;font-family:var(--font-mono);font-size:11.5px;");
                builder.AddAttribute(13, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e =>
                {
                    var s = e.Value?.ToString();
                    if (double.TryParse(s, NumberStyles.Any, CultureInfo.InvariantCulture, out var d)) setter(d);
                }));
                builder.CloseElement();

                builder.OpenElement(14, "span");
                builder.AddAttribute(15, "class", "p-unit");
                builder.AddContent(16, "mm");
                builder.CloseElement();
            }
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private void SetFontSize(string? raw)
    {
        if (!double.TryParse(raw, NumberStyles.Any, CultureInfo.InvariantCulture, out var d)) return;
        Apply(el => { if (HasTextContent(el)) el.FontSize = d; });
    }

    private void SetForeColor(string? hex)
    {
        if (string.IsNullOrEmpty(hex)) return;
        try
        {
            var c = Color.FromHex(hex);
            Apply(el => { if (HasTextContent(el)) el.ForeColor = c; });
        }
        catch { /* invalid hex — ignore */ }
    }

    private static bool HasTextContent(ElementViewModel e)
        => e.Kind is DesignerElementKind.Label or DesignerElementKind.TextBox or DesignerElementKind.Barcode;

    private static string ColorHex(Color c)
    {
        var h = c.ToHex();
        return h.Length == 9 ? "#" + h[3..] : h;
    }

    private string KindsBreakdown()
    {
        var groups = Selection.GroupBy(e => e.Kind).OrderByDescending(g => g.Count()).ToArray();
        if (groups.Length == 1) return $"{groups[0].Count()}× {groups[0].Key}";
        return string.Join(" · ", groups.Select(g => $"{g.Count()}× {g.Key}"));
    }
}
