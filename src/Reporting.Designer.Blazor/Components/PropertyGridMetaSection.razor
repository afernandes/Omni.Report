@using System.Globalization
@using Reporting.Designer.Blazor.Services
@using Reporting.Designer.Blazor.ViewModels
@using Reporting.Geometry
@using Reporting.Styling

@*
    Metadata-driven section: renders every [PropertyGrid]-annotated property of the selected element
    (base + derived, discovered by reflection) with the editor inferred from its type, plus an "fx"
    toggle per bindable property that drives it by a report expression (stored in PropertyExpressions).
    A new element that derives from an existing one gets all this automatically — no hand-coded UI.
*@

@foreach (var group in _descriptors.GroupBy(d => d.Category))
{
    <div class="prop-section">
        <div class="prop-section-head">
            <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
            <span>@group.Key</span>
            <span class="count">@group.Count()</span>
        </div>
        @foreach (var d in group)
        {
            var path = d.Path;
            var expr = Element.GetPropertyExpression(path);
            var bound = expr is not null;
            var current = Element.GetMetaValue(d);
            if (d.Editor is "list" or "dict")
            {
                // A list/dict spans the full width (label on top, items below) — a label|editor grid is too tight.
                <div class="prop-row" style="display:flex;flex-direction:column;align-items:stretch;gap:4px;padding:6px 10px;">
                    <div class="p-label" style="border:0;padding:0;">@d.Label</div>
                    @if (d.Editor == "list")
                    {
                        <PropertyGridListEditor Element="Element" Descriptor="d" />
                    }
                    else
                    {
                        <PropertyGridDictEditor Element="Element" Descriptor="d" />
                    }
                </div>
                continue;
            }
            <div class="prop-row @(bound ? "is-bound" : null)">
                <div class="p-label">@d.Label</div>
                <div class="p-editor">
                    @if (bound)
                    {
                        <span class="mono" title="@expr (clique para editar)"
                              @onclick="@(() => OnEditExpression.InvokeAsync(path))"
                              style="flex:1;font-size:11px;color:var(--data-bound);cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@expr</span>
                    }
                    else
                    {
                        @switch (d.Editor)
                        {
                            case "enum":
                                <select style="flex:1;font-size:11.5px;"
                                        @onchange="@(e => Element.ApplyMetaSet(d, Enum.Parse(EnumType(d), e.Value?.ToString() ?? string.Empty, ignoreCase: true)))">
                                    @foreach (var v in Enum.GetValues(EnumType(d)))
                                    {
                                        <option value="@v" selected="@(Equals(current, v))">@v</option>
                                    }
                                </select>
                                break;

                            case "color-picker":
                                var col = current as Color?;
                                <span class="color-swatch" style="background:@(col is { } c ? c.ToHex() : "transparent");@(col is null ? "border-style:dashed;" : null)"></span>
                                <input type="color" value="@ToRgbHex(col ?? Color.Black)"
                                       @onchange="@(e => Element.ApplyMetaSet(d, WithRgb(col ?? Color.Black, e.Value?.ToString())))"
                                       style="width:36px;height:16px;cursor:pointer;" />
                                @if (col is not null && IsNullable(d))
                                {
                                    <button class="icon-btn" type="button" title="Limpar" @onclick="@(() => Element.ApplyMetaSet(d, null))"
                                            style="width:18px;height:18px;">×</button>
                                }
                                break;

                            case "unit-spinner":
                                var unit = current is Unit u ? u : Unit.Zero;
                                <input type="number" step="0.1" value="@unit.ToMm().ToString("0.##", CultureInfo.InvariantCulture)"
                                       @onchange="@(e => Element.ApplyMetaSet(d, Unit.FromMm(ParseDouble(e.Value))))"
                                       style="width:64px;font-size:11.5px;" />
                                <span class="p-unit">mm</span>
                                break;

                            case "number":
                                <input type="number" step="0.1" value="@Convert.ToString(current, CultureInfo.InvariantCulture)"
                                       @onchange="@(e => Element.ApplyMetaSet(d, ConvertNumber(d, e.Value)))"
                                       style="width:64px;font-size:11.5px;" />
                                break;

                            case "toggle":
                                var on = current is true;
                                <span class="editor-toggle">
                                    <button class="@(on ? "is-on" : null)" @onclick="@(() => Element.ApplyMetaSet(d, true))">On</button>
                                    <button class="@(!on ? "is-on" : null)" @onclick="@(() => Element.ApplyMetaSet(d, false))">Off</button>
                                </span>
                                break;

                            case "font":
                                var font = current as Font ?? new Font("Arial", 10);
                                <input value="@font.Family" title="Família"
                                       @onchange="@(e => Element.ApplyMetaSet(d, font with { Family = string.IsNullOrWhiteSpace(e.Value?.ToString()) ? "Arial" : e.Value!.ToString()! }))"
                                       style="width:84px;font-family:var(--font-mono);font-size:11.5px;" />
                                <input type="number" step="0.5" title="Tamanho (pt)" value="@font.Size.ToString("0.##", CultureInfo.InvariantCulture)"
                                       @onchange="@(e => Element.ApplyMetaSet(d, font with { Size = ParseDouble(e.Value) }))"
                                       style="width:42px;font-family:var(--font-mono);font-size:11.5px;text-align:right;" />
                                <span class="p-unit">pt</span>
                                <span class="editor-toggle">
                                    <button type="button" class="@(font.Style.HasFlag(FontStyle.Bold) ? "is-on" : null)" @onclick="@(() => Element.ApplyMetaSet(d, font with { Style = font.Style ^ FontStyle.Bold }))">B</button>
                                    <button type="button" class="@(font.Style.HasFlag(FontStyle.Italic) ? "is-on" : null)" @onclick="@(() => Element.ApplyMetaSet(d, font with { Style = font.Style ^ FontStyle.Italic }))">I</button>
                                    <button type="button" class="@(font.Style.HasFlag(FontStyle.Underline) ? "is-on" : null)" @onclick="@(() => Element.ApplyMetaSet(d, font with { Style = font.Style ^ FontStyle.Underline }))">U</button>
                                    <button type="button" class="@(font.Style.HasFlag(FontStyle.Strikeout) ? "is-on" : null)" @onclick="@(() => Element.ApplyMetaSet(d, font with { Style = font.Style ^ FontStyle.Strikeout }))">S</button>
                                </span>
                                break;

                            case "h-align":
                                var ha = current is HorizontalAlignment hv ? hv : HorizontalAlignment.Left;
                                <span class="align-row" aria-label="Horizontal">
                                    <button type="button" class="@(ha == HorizontalAlignment.Left ? "is-on" : null)" title="Esquerda" @onclick="@(() => Element.ApplyMetaSet(d, HorizontalAlignment.Left))"><Icon Name="align-left" Size="12" CssClass="icon icon-12" /></button>
                                    <button type="button" class="@(ha == HorizontalAlignment.Center ? "is-on" : null)" title="Centro" @onclick="@(() => Element.ApplyMetaSet(d, HorizontalAlignment.Center))"><Icon Name="align-center" Size="12" CssClass="icon icon-12" /></button>
                                    <button type="button" class="@(ha == HorizontalAlignment.Right ? "is-on" : null)" title="Direita" @onclick="@(() => Element.ApplyMetaSet(d, HorizontalAlignment.Right))"><Icon Name="align-right" Size="12" CssClass="icon icon-12" /></button>
                                </span>
                                break;

                            case "v-align":
                                var va = current is VerticalAlignment vv ? vv : VerticalAlignment.Top;
                                <span class="align-row" aria-label="Vertical">
                                    <button type="button" class="@(va == VerticalAlignment.Top ? "is-on" : null)" title="Topo" @onclick="@(() => Element.ApplyMetaSet(d, VerticalAlignment.Top))"><Icon Name="align-start-horizontal" Size="12" CssClass="icon icon-12" /></button>
                                    <button type="button" class="@(va == VerticalAlignment.Middle ? "is-on" : null)" title="Centro" @onclick="@(() => Element.ApplyMetaSet(d, VerticalAlignment.Middle))"><Icon Name="align-center-horizontal" Size="12" CssClass="icon icon-12" /></button>
                                    <button type="button" class="@(va == VerticalAlignment.Bottom ? "is-on" : null)" title="Base" @onclick="@(() => Element.ApplyMetaSet(d, VerticalAlignment.Bottom))"><Icon Name="align-end-horizontal" Size="12" CssClass="icon icon-12" /></button>
                                </span>
                                break;

                            case "border":
                                var border = current as Border;
                                var bside = FirstVisibleSide(border);
                                <select style="flex:1;font-size:11.5px;"
                                        @onchange="@(e => Element.ApplyMetaSet(d, WithBorderStyle(border, e.Value?.ToString())))">
                                    <option value="None" selected="@(bside is null || bside.Style == BorderLineStyle.None)">— Nenhuma —</option>
                                    <option value="Solid" selected="@(bside?.Style == BorderLineStyle.Solid)">Solid</option>
                                    <option value="Dashed" selected="@(bside?.Style == BorderLineStyle.Dashed)">Dashed</option>
                                    <option value="Dotted" selected="@(bside?.Style == BorderLineStyle.Dotted)">Dotted</option>
                                    <option value="DashDot" selected="@(bside?.Style == BorderLineStyle.DashDot)">DashDot</option>
                                    <option value="Double" selected="@(bside?.Style == BorderLineStyle.Double)">Double</option>
                                </select>
                                @if (bside is not null && bside.Style != BorderLineStyle.None)
                                {
                                    <input type="number" step="0.1" min="0" max="10" value="@bside.Thickness.ToPoints().ToString("F1", CultureInfo.InvariantCulture)"
                                           @onchange="@(e => Element.ApplyMetaSet(d, WithBorderThickness(border!, ParseDouble(e.Value))))"
                                           style="width:52px;font-family:var(--font-mono);font-size:11.5px;" />
                                    <span class="p-unit">pt</span>
                                    <input type="color" value="@ToRgbHex(bside.Color)"
                                           @onchange="@(e => Element.ApplyMetaSet(d, WithBorderColor(border!, e.Value?.ToString())))"
                                           style="width:36px;height:16px;cursor:pointer;" />
                                }
                                break;

                            case "padding":
                                var pad = current as Thickness?;
                                <input type="number" step="0.1" min="0" value="@((pad?.Top.ToMm() ?? 0).ToString("F1", CultureInfo.InvariantCulture))"
                                       @onchange="@(e => Element.ApplyMetaSet(d, PaddingFromMm(ParseDouble(e.Value))))"
                                       style="width:60px;font-family:var(--font-mono);font-size:11.5px;" />
                                <span class="p-unit">mm</span>
                                break;

                            case "format-preset":
                                var fmt = current as string ?? string.Empty;
                                var isCustom = _customFormat.Contains(d.Path) || (!string.IsNullOrEmpty(fmt) && !KnownFormats.Contains(fmt));
                                <select style="flex:1;font-size:11.5px;font-family:var(--font-mono);"
                                        @onchange="@(e => OnFormatPreset(d, e.Value?.ToString()))">
                                    <option value="" selected="@(string.IsNullOrEmpty(fmt))">— sem formato —</option>
                                    <option value="C" selected="@(fmt == "C")">C — Moeda (R$ 1.234,56)</option>
                                    <option value="N0" selected="@(fmt == "N0")">N0 — Inteiro (1.234)</option>
                                    <option value="N2" selected="@(fmt == "N2")">N2 — Decimal (1.234,56)</option>
                                    <option value="P" selected="@(fmt == "P")">P — Percent (12,34%)</option>
                                    <option value="dd/MM/yyyy" selected="@(fmt == "dd/MM/yyyy")">Data dd/MM/yyyy</option>
                                    <option value="HH:mm" selected="@(fmt == "HH:mm")">Hora HH:mm</option>
                                    <option value="dd/MM/yyyy HH:mm" selected="@(fmt == "dd/MM/yyyy HH:mm")">Data+Hora</option>
                                    <option value="__custom__" selected="@isCustom">— Custom… —</option>
                                </select>
                                @if (isCustom)
                                {
                                    <input type="text" value="@fmt" placeholder="ex: #,##0.00"
                                           @onchange="@(e => Element.ApplyMetaSet(d, string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value!.ToString()))"
                                           style="width:120px;font-family:var(--font-mono);font-size:11.5px;" />
                                }
                                break;

                            case "textarea":
                                <textarea @onchange="@(e => Element.ApplyMetaSet(d, e.Value?.ToString()))" rows="3"
                                          placeholder="@d.Placeholder"
                                          style="flex:1;font-family:var(--font-mono);font-size:11px;resize:vertical;">@Convert.ToString(current)</textarea>
                                break;

                            case "color-hex":
                                var hex = current as string ?? "#000000";
                                <input type="color" value="@hex"
                                       @onchange="@(e => Element.ApplyMetaSet(d, e.Value?.ToString() ?? hex))"
                                       style="width:36px;height:16px;cursor:pointer;" />
                                <span class="mono" style="font-size:11px;">@hex</span>
                                break;

                            default:
                                <input type="text" value="@Convert.ToString(current)" placeholder="@d.Placeholder"
                                       @onchange="@(e => Element.ApplyMetaSet(d, e.Value?.ToString()))"
                                       style="flex:1;font-size:11.5px;" />
                                break;
                        }
                    }
                    @if (d.Bindable)
                    {
                        <button class="icon-btn" type="button"
                                title="@(bound ? "Editar expressão (fx)" : "Vincular a expressão (fx)")"
                                @onclick="@(() => OnEditExpression.InvokeAsync(path))"
                                style="width:18px;height:18px;border-radius:3px;font-family:var(--font-mono);font-size:9.5px;font-weight:600;cursor:pointer;color:@(bound ? "var(--bg-canvas)" : "var(--data-bound)");background:@(bound ? "var(--data-bound)" : "var(--data-bound-soft)");">fx</button>
                        @if (bound)
                        {
                            <button class="icon-btn" type="button" title="Remover expressão (voltar ao valor fixo)"
                                    @onclick="@(() => Element.SetPropertyExpression(path, null))"
                                    style="width:18px;height:18px;color:var(--text-tertiary);">×</button>
                        }
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public ElementViewModel Element { get; set; } = default!;

    /// <summary>Raised when the user clicks "fx" on a bindable property — the argument is the property
    /// path. The host opens the rich expression editor (Monaco) seeded with the current binding and
    /// writes the result back to <c>PropertyExpressions[path]</c>.</summary>
    [Parameter] public EventCallback<string> OnEditExpression { get; set; }

    private IReadOnlyList<PropertyGridDescriptor> _descriptors = Array.Empty<PropertyGridDescriptor>();

    protected override void OnParametersSet()
        => _descriptors = PropertyGridDescriptors.For(Element.ToElement().GetType());

    private static Type EnumType(PropertyGridDescriptor d) => Nullable.GetUnderlyingType(d.Type) ?? d.Type;

    private static bool IsNullable(PropertyGridDescriptor d)
        => Nullable.GetUnderlyingType(d.Type) is not null || !d.Type.IsValueType;

    private static double ParseDouble(object? value)
        => double.TryParse(Convert.ToString(value, CultureInfo.InvariantCulture),
            NumberStyles.Any, CultureInfo.InvariantCulture, out var x) ? x : 0;

    private static object ConvertNumber(PropertyGridDescriptor d, object? value)
        => Convert.ChangeType(ParseDouble(value), Nullable.GetUnderlyingType(d.Type) ?? d.Type, CultureInfo.InvariantCulture);

    // ── Format preset: a dropdown of common .NET format strings + a custom escape hatch.
    private static readonly HashSet<string> KnownFormats = new(StringComparer.Ordinal)
    {
        "C", "N0", "N2", "P", "dd/MM/yyyy", "HH:mm", "dd/MM/yyyy HH:mm",
    };

    // Paths whose format-preset dropdown is in "Custom…" mode — kept in local UI state so selecting Custom
    // opens the text input WITHOUT persisting a bogus literal format ("custom" was being written as the
    // .NET format string, corrupting the rendered value). Typing a real value persists it.
    private readonly HashSet<string> _customFormat = new();

    private void OnFormatPreset(PropertyGridDescriptor d, string? value)
    {
        if (value == "__custom__")
        {
            _customFormat.Add(d.Path);
            return;
        }
        _customFormat.Remove(d.Path);
        Element.ApplyMetaSet(d, string.IsNullOrEmpty(value) ? null : value);
    }

    private static string ToRgbHex(Color c) => string.Create(CultureInfo.InvariantCulture, $"#{c.R:X2}{c.G:X2}{c.B:X2}");

    // <input type=color> only round-trips #RRGGBB; preserve the element's existing alpha instead of forcing opaque.
    private static object WithRgb(Color old, string? hex) => Color.FromHex(hex ?? "#000000") with { A = old.A };

    // Show the first VISIBLE side so a non-uniform border (e.g. bottom-only, built code-first / loaded from
    // a file) doesn't read as "Nenhuma". Editing still applies uniformly to all four sides (see below).
    private static BorderSide? FirstVisibleSide(Border? b)
    {
        if (b is null)
        {
            return null;
        }
        foreach (var side in new[] { b.Top, b.Right, b.Bottom, b.Left })
        {
            if (side.Style != BorderLineStyle.None)
            {
                return side;
            }
        }
        return b.Top;
    }

    // ── Border / Padding: edit the box uniformly (all four sides the same), matching the previous
    //    hand-coded editors. A "None" style clears the border; a non-positive padding clears it.
    private static Border? WithBorderStyle(Border? current, string? styleName)
    {
        if (string.IsNullOrEmpty(styleName) || !Enum.TryParse<BorderLineStyle>(styleName, out var style) || style == BorderLineStyle.None)
        {
            return null;
        }
        var side = (current?.Top ?? new BorderSide(BorderLineStyle.Solid, Unit.FromPoint(0.5), Color.Black)) with { Style = style };
        return new Border(side, side, side, side);
    }

    private static Border WithBorderThickness(Border current, double points)
    {
        var side = current.Top with { Thickness = Unit.FromPoint(points) };
        return new Border(side, side, side, side);
    }

    private static Border WithBorderColor(Border current, string? hex)
    {
        if (string.IsNullOrEmpty(hex))
        {
            return current;
        }
        try
        {
            // Keep the existing alpha — the colour input only provides #RRGGBB.
            var side = current.Top with { Color = Color.FromHex(hex) with { A = current.Top.Color.A } };
            return new Border(side, side, side, side);
        }
        catch (FormatException)
        {
            return current;
        }
    }

    private static Thickness? PaddingFromMm(double mm)
    {
        if (mm <= 0)
        {
            return null;
        }
        var u = Unit.FromMm(mm);
        return new Thickness(u, u, u, u);
    }
}
