@namespace Reporting.Designer.Blazor.Components
@using System.Globalization
@using Reporting.Elements
@implements IDisposable

@if (Element is null)
{
    <div style="padding:24px 16px; color:var(--text-tertiary); font-size:var(--fs-sm);">
        Selecione um elemento para editar suas propriedades.
    </div>
}
else
{
    <!-- Header chip: element kind + name + selection count -->
    <div style="display:flex;align-items:center;gap:8px;height:34px;padding:0 12px;border-bottom:1px solid var(--border);background:var(--bg-surface);">
        <Icon Name="@KindIcon(Element)" Size="16" CssClass="icon icon-16" />
        <div style="flex:1;min-width:0;">
            <div style="font-size:12px;font-weight:600;color:var(--text-primary);">
                @Element.Kind · @(Element.Name ?? Element.Id[..Math.Min(6, Element.Id.Length)])
            </div>
            <div style="font-size:10px;color:var(--text-tertiary);font-family:var(--font-mono);">
                @BandLabel · #@Element.Id[..Math.Min(6, Element.Id.Length)]
            </div>
        </div>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-tertiary);padding:1px 5px;border:1px solid var(--border);border-radius:2px;">1 sel.</span>
    </div>

    <div class="prop-section">
        <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Layout</span><span class="count">4</span></div>
        @Row("X",      ToMm(Element.X),      v => Element.X      = ParseMm(v) ?? Element.X)
        @Row("Y",      ToMm(Element.Y),      v => Element.Y      = ParseMm(v) ?? Element.Y)
        @Row("Width",  ToMm(Element.Width),  v => Element.Width  = ParseMm(v) ?? Element.Width)
        @Row("Height", ToMm(Element.Height), v => Element.Height = ParseMm(v) ?? Element.Height)
    </div>

    @if (HasTextContent(Element))
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Appearance</span><span class="count">5</span></div>
            <div class="prop-row">
                <div class="p-label">Font</div>
                <div class="p-editor">
                    <input value="@Element.FontFamily"
                           @onchange="@(e => Element.FontFamily = e.Value?.ToString() ?? "Arial")"
                           style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                    <span style="color:var(--text-tertiary);">·</span>
                    <input value="@Element.FontSize" type="number" step="0.5"
                           @onchange="@(e => SetFontSize(e.Value?.ToString()))"
                           style="width:46px;font-family:var(--font-mono);font-size:11.5px;text-align:right;" />
                    <span class="p-unit">pt</span>
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Style</div>
                <div class="p-editor">
                    <span class="editor-toggle">
                        <button class="@(Element.IsBold ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.IsBold = !Element.IsBold)">B</button>
                        <button class="@(Element.IsItalic ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.IsItalic = !Element.IsItalic)">I</button>
                        <button class="@(Element.IsUnderline ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.IsUnderline = !Element.IsUnderline)">U</button>
                        <button class="@(Element.IsStrikethrough ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.IsStrikethrough = !Element.IsStrikethrough)">S</button>
                    </span>
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Color</div>
                <div class="p-editor">
                    <span class="color-swatch" style="background:@ColorHex(Element.ForeColor);"></span>
                    <input type="color" value="@ColorHex(Element.ForeColor)"
                           @onchange="@(e => SetColor(e.Value?.ToString()))"
                           style="width:36px;height:16px;cursor:pointer;" />
                    <span class="mono" style="font-size:11.5px;">@ColorHex(Element.ForeColor)</span>
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Background</div>
                <div class="p-editor">
                    @{
                        var bg = Element.BackColor ?? Element.FillColor;
                    }
                    @if (bg is null)
                    {
                        <span class="color-swatch" style="background:transparent;border-style:dashed;"></span>
                        <input type="color" value="#ffffff"
                               @onchange="@(e => SetBackground(e.Value?.ToString()))"
                               style="width:36px;height:16px;cursor:pointer;" />
                        <span style="color:var(--text-tertiary);font-size:11.5px;">Transparente</span>
                        <button class="icon-btn" type="button" title="Definir transparente"
                                @onclick="ClearBackground"
                                style="width:18px;height:18px;color:var(--text-tertiary);">×</button>
                    }
                    else
                    {
                        <span class="color-swatch" style="background:@ColorHex(bg.Value);"></span>
                        <input type="color" value="@ColorHex(bg.Value)"
                               @onchange="@(e => SetBackground(e.Value?.ToString()))"
                               style="width:36px;height:16px;cursor:pointer;" />
                        <span class="mono" style="font-size:11.5px;">@ColorHex(bg.Value)</span>
                        <button class="icon-btn" type="button" title="Tornar transparente"
                                @onclick="ClearBackground"
                                style="width:18px;height:18px;color:var(--text-tertiary);">×</button>
                    }
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Align H</div>
                <div class="p-editor">
                    <span class="align-row" aria-label="Horizontal">
                        <button class="@(Element.HorizontalAlignment == HorizontalAlignment.Left ? "is-on" : null)" type="button"
                                title="Esquerda" @onclick="@(() => Element.HorizontalAlignment = HorizontalAlignment.Left)">
                            <Icon Name="align-left" Size="12" CssClass="icon icon-12" />
                        </button>
                        <button class="@(Element.HorizontalAlignment == HorizontalAlignment.Center ? "is-on" : null)" type="button"
                                title="Centro" @onclick="@(() => Element.HorizontalAlignment = HorizontalAlignment.Center)">
                            <Icon Name="align-center" Size="12" CssClass="icon icon-12" />
                        </button>
                        <button class="@(Element.HorizontalAlignment == HorizontalAlignment.Right ? "is-on" : null)" type="button"
                                title="Direita" @onclick="@(() => Element.HorizontalAlignment = HorizontalAlignment.Right)">
                            <Icon Name="align-right" Size="12" CssClass="icon icon-12" />
                        </button>
                    </span>
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Align V</div>
                <div class="p-editor">
                    <span class="align-row" aria-label="Vertical">
                        <button class="@(Element.VerticalAlignment == VerticalAlignment.Top ? "is-on" : null)" type="button"
                                title="Topo" @onclick="@(() => Element.VerticalAlignment = VerticalAlignment.Top)">
                            <Icon Name="align-start-horizontal" Size="12" CssClass="icon icon-12" />
                        </button>
                        <button class="@(Element.VerticalAlignment == VerticalAlignment.Middle ? "is-on" : null)" type="button"
                                title="Centro" @onclick="@(() => Element.VerticalAlignment = VerticalAlignment.Middle)">
                            <Icon Name="align-center-horizontal" Size="12" CssClass="icon icon-12" />
                        </button>
                        <button class="@(Element.VerticalAlignment == VerticalAlignment.Bottom ? "is-on" : null)" type="button"
                                title="Base" @onclick="@(() => Element.VerticalAlignment = VerticalAlignment.Bottom)">
                            <Icon Name="align-end-horizontal" Size="12" CssClass="icon icon-12" />
                        </button>
                    </span>
                </div>
            </div>
        </div>

        @* ── Border + Padding section ──────────────────────────────────────── *@
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Border &amp; Padding</span><span class="count">2</span></div>
            <div class="prop-row">
                <div class="p-label">Border</div>
                <div class="p-editor">
                    <select @onchange="@(e => SetBorderStyle(e.Value?.ToString()))" style="flex:1;font-size:11.5px;">
                        <option value="None" selected="@(Element.Border is null || Element.Border.Top.Style == BorderLineStyle.None)">— Nenhuma —</option>
                        <option value="Solid"  selected="@(Element.Border?.Top.Style == BorderLineStyle.Solid)">Solid</option>
                        <option value="Dashed" selected="@(Element.Border?.Top.Style == BorderLineStyle.Dashed)">Dashed</option>
                        <option value="Dotted" selected="@(Element.Border?.Top.Style == BorderLineStyle.Dotted)">Dotted</option>
                        <option value="Double" selected="@(Element.Border?.Top.Style == BorderLineStyle.Double)">Double</option>
                    </select>
                    @if (Element.Border is not null && Element.Border.Top.Style != BorderLineStyle.None)
                    {
                        <input type="number" step="0.1" min="0" max="10"
                               value="@BorderThickness"
                               @onchange="@(e => SetBorderThickness(e.Value?.ToString()))"
                               style="width:52px;font-family:var(--font-mono);font-size:11.5px;" />
                        <span class="p-unit">pt</span>
                        <input type="color"
                               value="@ColorHex(Element.Border.Top.Color)"
                               @onchange="@(e => SetBorderColor(e.Value?.ToString()))"
                               style="width:36px;height:16px;cursor:pointer;" />
                    }
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Padding</div>
                <div class="p-editor">
                    <input type="number" step="0.1" min="0"
                           value="@PaddingMm"
                           @onchange="@(e => SetUniformPadding(e.Value?.ToString()))"
                           style="width:60px;font-family:var(--font-mono);font-size:11.5px;" />
                    <span class="p-unit">mm</span>
                    <span style="color:var(--text-tertiary);font-size:10.5px;">(uniforme)</span>
                </div>
            </div>
        </div>

        <div class="prop-section">
            <div class="prop-section-head" style="background:var(--accent-soft);color:var(--accent);">
                <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
                <span>Data</span>
                <span class="count" style="color:var(--accent);background:var(--bg-surface);border:1px solid var(--accent-border);padding:1px 4px;border-radius:2px;">@(IsBound ? 2 : 1)</span>
            </div>
            <div class="prop-row @(IsBound ? "is-bound is-focused" : null)">
                <div class="p-label">@(Element.Kind == DesignerElementKind.Label ? "Text" : "Expression")</div>
                <div class="p-editor">
                    @if (Element.Kind == DesignerElementKind.Label)
                    {
                        <input type="text" value="@Element.Text"
                               @onchange="@(e => Element.Text = e.Value?.ToString() ?? string.Empty)"
                               style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                    }
                    else
                    {
                        <input type="text" value="@Element.Expression"
                               @onchange="@(e => Element.Expression = e.Value?.ToString() ?? string.Empty)"
                               style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                        <button class="icon-btn" type="button"
                                @onclick="OpenExpressionEditor"
                                style="width:18px;height:18px;color:var(--data-bound);background:var(--data-bound-soft);border-radius:3px;font-family:var(--font-mono);font-size:9.5px;font-weight:600;cursor:pointer;"
                                title="Editor de expressões (F8)">fx</button>
                    }
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Format</div>
                <div class="p-editor">
                    <select @onchange="@(e => SetFormatPreset(e.Value?.ToString()))" style="flex:1;font-size:11.5px;font-family:var(--font-mono);">
                        <option value=""    selected="@(string.IsNullOrEmpty(Element.Format))">— sem formato —</option>
                        <option value="C"   selected="@(Element.Format == "C")">C — Moeda (R$ 1.234,56)</option>
                        <option value="N0"  selected="@(Element.Format == "N0")">N0 — Inteiro (1.234)</option>
                        <option value="N2"  selected="@(Element.Format == "N2")">N2 — Decimal (1.234,56)</option>
                        <option value="P"   selected="@(Element.Format == "P")">P — Percent (12,34%)</option>
                        <option value="dd/MM/yyyy" selected="@(Element.Format == "dd/MM/yyyy")">Data dd/MM/yyyy</option>
                        <option value="HH:mm"      selected="@(Element.Format == "HH:mm")">Hora HH:mm</option>
                        <option value="dd/MM/yyyy HH:mm" selected="@(Element.Format == "dd/MM/yyyy HH:mm")">Data+Hora</option>
                        <option value="__custom__" selected="@(!string.IsNullOrEmpty(Element.Format) && !_knownFormats.Contains(Element.Format!))">— Custom… —</option>
                    </select>
                    @if (!string.IsNullOrEmpty(Element.Format) && !_knownFormats.Contains(Element.Format!))
                    {
                        <input type="text" value="@Element.Format" placeholder="ex: #,##0.00"
                               @onchange="@(e => Element!.Format = e.Value?.ToString())"
                               style="width:120px;font-family:var(--font-mono);font-size:11.5px;" />
                    }
                </div>
            </div>
        </div>
    }

    <div class="prop-section">
        <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Behavior</span><span class="count">3</span></div>
        <div class="prop-row">
            <div class="p-label">Visible</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element!.IsVisible ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.IsVisible = true)">On</button>
                    <button class="@(!Element.IsVisible ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.IsVisible = false)">Off</button>
                </span>
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label">CanGrow</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element.CanGrow ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.CanGrow = true)">On</button>
                    <button class="@(!Element.CanGrow ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.CanGrow = false)">Off</button>
                </span>
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label">KeepTogether</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element.KeepTogether ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.KeepTogether = true)">On</button>
                    <button class="@(!Element.KeepTogether ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.KeepTogether = false)">Off</button>
                </span>
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label">Locked</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element.IsLocked ? "is-on" : null)" type="button"
                            title="Bloqueia drag/resize" @onclick="@(() => Element.IsLocked = true)">On</button>
                    <button class="@(!Element.IsLocked ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.IsLocked = false)">Off</button>
                </span>
                @if (Element.IsLocked)
                {
                    <Icon Name="lock" Size="12" CssClass="icon icon-12" />
                }
            </div>
        </div>
    </div>

    @* ── Image upload (when element kind is Image) ────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Image)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Image</span></div>
            <div class="prop-row">
                <div class="p-label">Source</div>
                <div class="p-editor" style="flex-direction:column;align-items:stretch;gap:6px;">
                    <InputFile OnChange="OnImageSelected" accept="image/png,image/jpeg,image/gif"
                               style="font-size:11.5px;" />
                    @if (Element.InlineImageData is { Length: > 0 })
                    {
                        <div style="display:flex;align-items:center;gap:6px;">
                            <img src="@($"data:image/png;base64,{Convert.ToBase64String(Element.InlineImageData)}")"
                                 alt="thumb" style="max-width:60px;max-height:60px;border:1px solid var(--border);" />
                            <span style="font-size:10.5px;color:var(--text-tertiary);">@(Element.InlineImageData.Length / 1024) KB</span>
                            <button class="icon-btn" type="button" title="Remover imagem"
                                    @onclick="@(() => Element.InlineImageData = null)"
                                    style="width:18px;height:18px;color:var(--text-tertiary);">×</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* ── Chart editor (when element kind is Chart) ──────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Chart)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Gráfico</span><span class="count">@Element.ChartSeries.Count</span></div>
            <div class="prop-row">
                <div class="p-label">Tipo</div>
                <div class="p-editor">
                    <select value="@Element.ChartKind"
                            @onchange="@(e => Element.ChartKind = Enum.TryParse<ChartKind>(e.Value?.ToString(), out var k) ? k : ChartKind.Bar)"
                            style="flex:1;font-size:11.5px;">
                        @foreach (var k in Enum.GetValues<ChartKind>())
                        {
                            <option value="@k">@k</option>
                        }
                    </select>
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Título</div>
                <div class="p-editor">
                    <input type="text" value="@Element.ChartTitle" placeholder="(sem título)"
                           @onchange="@(e => Element.ChartTitle = e.Value?.ToString() ?? string.Empty)"
                           style="flex:1;font-size:11.5px;" />
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Legenda</div>
                <div class="p-editor">
                    <label style="font-size:11px;"><input type="checkbox" checked="@Element.ShowLegend"
                           @onchange="@(e => Element.ShowLegend = (bool)(e.Value ?? false))" /> Mostrar</label>
                </div>
            </div>
            <div style="padding:6px 10px;">
                @foreach (var (s, i) in Element.ChartSeries.Select((s, i) => (s, i)).ToArray())
                {
                    <div style="border:1px solid var(--border-soft);padding:6px;margin-bottom:6px;border-radius:var(--r-2);background:var(--bg-panel);">
                        <div style="display:flex;align-items:center;gap:4px;margin-bottom:4px;">
                            <span style="font-size:10.5px;color:var(--text-tertiary);flex:1;">Série @(i + 1)</span>
                            <button class="icon-btn" type="button" title="Remover"
                                    @onclick="@(() => Element.ChartSeries.Remove(s))"
                                    style="width:18px;height:18px;color:var(--danger);">×</button>
                        </div>
                        <input type="text" value="@s.Name" placeholder="Nome da série"
                               @onchange="@(e => s.Name = e.Value?.ToString() ?? string.Empty)"
                               style="width:100%;font-size:11px;margin-bottom:4px;" />
                        <input type="text" value="@s.CategoryExpression" placeholder="Fields.Categoria"
                               @onchange="@(e => s.CategoryExpression = e.Value?.ToString() ?? string.Empty)"
                               style="width:100%;font-family:var(--font-mono);font-size:11px;margin-bottom:4px;" />
                        <input type="text" value="@s.ValueExpression" placeholder="Fields.Valor"
                               @onchange="@(e => s.ValueExpression = e.Value?.ToString() ?? string.Empty)"
                               style="width:100%;font-family:var(--font-mono);font-size:11px;" />
                        @if (Element.ChartKind == ChartKind.Bubble)
                        {
                            <input type="text" value="@s.SizeExpression" placeholder="Tamanho (Fields.X)"
                                   @onchange="@(e => s.SizeExpression = e.Value?.ToString() ?? string.Empty)"
                                   style="width:100%;font-family:var(--font-mono);font-size:11px;margin-top:4px;" />
                        }
                        @if (Element.ChartKind == ChartKind.Stock)
                        {
                            <input type="text" value="@s.HighExpression" placeholder="Máxima (Fields.High)"
                                   @onchange="@(e => s.HighExpression = e.Value?.ToString() ?? string.Empty)"
                                   style="width:100%;font-family:var(--font-mono);font-size:11px;margin-top:4px;" />
                            <input type="text" value="@s.LowExpression" placeholder="Mínima (Fields.Low)"
                                   @onchange="@(e => s.LowExpression = e.Value?.ToString() ?? string.Empty)"
                                   style="width:100%;font-family:var(--font-mono);font-size:11px;margin-top:4px;" />
                        }
                    </div>
                }
                <button class="btn" type="button" style="font-size:11px;padding:3px 8px;cursor:pointer;border:1px dashed var(--border);background:transparent;color:var(--text-secondary);width:100%;"
                        @onclick="@(() => Element.ChartSeries.Add(new ChartSeriesRule()))">+ Adicionar série</button>
            </div>
        </div>
    }

    @* ── DataBar editor ──────────────────────────────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.DataBar)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Barra de dados</span></div>
            <div class="prop-row"><div class="p-label">Valor</div><div class="p-editor">
                <input type="text" value="@Element.DataBarValue" placeholder="Fields.X"
                       @onchange="@(e => Element.DataBarValue = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Mín</div><div class="p-editor">
                <input type="text" value="@Element.DataBarMin"
                       @onchange="@(e => Element.DataBarMin = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Máx</div><div class="p-editor">
                <input type="text" value="@Element.DataBarMax"
                       @onchange="@(e => Element.DataBarMax = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Cor</div><div class="p-editor">
                <input type="color" value="@Element.DataBarFill"
                       @onchange="@(e => Element.DataBarFill = e.Value?.ToString() ?? "#C2410C")"
                       style="width:28px;height:18px;cursor:pointer;" /></div></div>
        </div>
    }

    @* ── Sparkline editor ────────────────────────────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Sparkline)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Mini-gráfico</span></div>
            <div class="prop-row"><div class="p-label">Tipo</div><div class="p-editor">
                <select value="@Element.SparkKind"
                        @onchange="@(e => Element.SparkKind = Enum.TryParse<SparklineKind>(e.Value?.ToString(), out var k) ? k : SparklineKind.Line)"
                        style="flex:1;font-size:11.5px;">
                    @foreach (var k in Enum.GetValues<SparklineKind>())
                    {
                        <option value="@k">@k</option>
                    }
                </select></div></div>
            <div class="prop-row"><div class="p-label">Valor</div><div class="p-editor">
                <input type="text" value="@Element.SparkValue" placeholder="Fields.Value"
                       @onchange="@(e => Element.SparkValue = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Fonte</div><div class="p-editor">
                <input type="text" value="@Element.SparkDataSet" placeholder="(fonte primária)"
                       @onchange="@(e => Element.SparkDataSet = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-size:11.5px;" /></div></div>
        </div>
    }

