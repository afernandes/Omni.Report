@namespace Reporting.Designer.Blazor.Components
@using System.Globalization
@using Reporting.Elements
@implements IDisposable

@if (Element is null)
{
    <div style="padding:24px 16px; color:var(--text-tertiary); font-size:var(--fs-sm);">
        Selecione um elemento para editar suas propriedades.
    </div>
}
else
{
    <!-- Header chip: element kind + name + selection count -->
    <div style="display:flex;align-items:center;gap:8px;height:34px;padding:0 12px;border-bottom:1px solid var(--border);background:var(--bg-surface);">
        <Icon Name="@KindIcon(Element)" Size="16" CssClass="icon icon-16" />
        <div style="flex:1;min-width:0;">
            <div style="font-size:12px;font-weight:600;color:var(--text-primary);">
                @Element.Kind · @(Element.Name ?? Element.Id[..Math.Min(6, Element.Id.Length)])
            </div>
            <div style="font-size:10px;color:var(--text-tertiary);font-family:var(--font-mono);">
                @BandLabel · #@Element.Id[..Math.Min(6, Element.Id.Length)]
            </div>
        </div>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-tertiary);padding:1px 5px;border:1px solid var(--border);border-radius:2px;">1 sel.</span>
    </div>

    <div class="prop-section">
        <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Layout</span><span class="count">4</span></div>
        @Row("X",      ToMm(Element.X),      v => Element.X      = ParseMm(v) ?? Element.X)
        @Row("Y",      ToMm(Element.Y),      v => Element.Y      = ParseMm(v) ?? Element.Y)
        @Row("Width",  ToMm(Element.Width),  v => Element.Width  = ParseMm(v) ?? Element.Width)
        @Row("Height", ToMm(Element.Height), v => Element.Height = ParseMm(v) ?? Element.Height)
    </div>

    @* "Data" stays a dedicated section (primary text/expression content + Monaco fx + format preset),
       but its visibility is now METADATA-driven via the [TextStyled] marker — no hard-coded kind list. *@
    @if (Element.IsTextStyled)
    {

        <div class="prop-section">
            <div class="prop-section-head" style="background:var(--accent-soft);color:var(--accent);">
                <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
                <span>Data</span>
                <span class="count" style="color:var(--accent);background:var(--bg-surface);border:1px solid var(--accent-border);padding:1px 4px;border-radius:2px;">1</span>
            </div>
            <div class="prop-row @(IsBound ? "is-bound is-focused" : null)">
                <div class="p-label">@(Element.Kind == DesignerElementKind.Label ? "Text" : "Expression")</div>
                <div class="p-editor">
                    @if (Element.Kind == DesignerElementKind.Label)
                    {
                        <input type="text" value="@Element.Text"
                               @onchange="@(e => Element.Text = e.Value?.ToString() ?? string.Empty)"
                               style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                    }
                    else
                    {
                        <input type="text" value="@Element.Expression"
                               @onchange="@(e => Element.Expression = e.Value?.ToString() ?? string.Empty)"
                               style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                        <button class="icon-btn" type="button"
                                @onclick="OpenExpressionEditor"
                                style="width:18px;height:18px;color:var(--data-bound);background:var(--data-bound-soft);border-radius:3px;font-family:var(--font-mono);font-size:9.5px;font-weight:600;cursor:pointer;"
                                title="Editor de expressões (F8)">fx</button>
                    }
                </div>
            </div>
        </div>
    }

    <div class="prop-section">
        <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Behavior</span><span class="count">5</span></div>
        <div class="prop-row">
            <div class="p-label">Visible</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element!.IsVisible ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.IsVisible = true)">On</button>
                    <button class="@(!Element.IsVisible ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.IsVisible = false)">Off</button>
                </span>
            </div>
        </div>
        <div class="prop-row"><div class="p-label">Visível se</div><div class="p-editor">
            <input type="text" value="@Element.VisibleExpr" placeholder="(opcional) Fields.Total > 0"
                   @onchange="@(e => Element.VisibleExpr = e.Value?.ToString())"
                   style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
        <div class="prop-row">
            <div class="p-label">CanGrow</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element.CanGrow ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.CanGrow = true)">On</button>
                    <button class="@(!Element.CanGrow ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.CanGrow = false)">Off</button>
                </span>
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label">CanShrink</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element.CanShrink ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.CanShrink = true)">On</button>
                    <button class="@(!Element.CanShrink ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.CanShrink = false)">Off</button>
                </span>
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label">KeepTogether</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element.KeepTogether ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.KeepTogether = true)">On</button>
                    <button class="@(!Element.KeepTogether ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.KeepTogether = false)">Off</button>
                </span>
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label">Locked</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(Element.IsLocked ? "is-on" : null)" type="button"
                            title="Bloqueia drag/resize" @onclick="@(() => Element.IsLocked = true)">On</button>
                    <button class="@(!Element.IsLocked ? "is-on" : null)" type="button"
                            @onclick="@(() => Element.IsLocked = false)">Off</button>
                </span>
                @if (Element.IsLocked)
                {
                    <Icon Name="lock" Size="12" CssClass="icon icon-12" />
                }
            </div>
        </div>
    </div>

    @* ── Image upload (when element kind is Image) ────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Image)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Image</span></div>
            <div class="prop-row">
                <div class="p-label">Source</div>
                <div class="p-editor" style="flex-direction:column;align-items:stretch;gap:6px;">
                    <InputFile OnChange="OnImageSelected" accept="image/png,image/jpeg,image/gif"
                               style="font-size:11.5px;" />
                    @if (Element.InlineImageData is { Length: > 0 })
                    {
                        <div style="display:flex;align-items:center;gap:6px;">
                            <img src="@($"data:image/png;base64,{Convert.ToBase64String(Element.InlineImageData)}")"
                                 alt="thumb" style="max-width:60px;max-height:60px;border:1px solid var(--border);" />
                            <span style="font-size:10.5px;color:var(--text-tertiary);">@(Element.InlineImageData.Length / 1024) KB</span>
                            <button class="icon-btn" type="button" title="Remover imagem"
                                    @onclick="@(() => Element.InlineImageData = null)"
                                    style="width:18px;height:18px;color:var(--text-tertiary);">×</button>
                        </div>
                    }
                </div>
            </div>
            <div class="prop-row"><div class="p-label">Caminho/URL</div><div class="p-editor">
                <input type="text" value="@Element.ImagePath" placeholder="/img/logo.png ou https://…"
                       @onchange="@(e => Element.ImagePath = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Expressão</div><div class="p-editor">
                <input type="text" value="@Element.ImageExpression" placeholder="(opcional) Fields.Foto"
                       @onchange="@(e => Element.ImageExpression = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Ajuste</div><div class="p-editor">
                <select value="@Element.ImageSizing"
                        @onchange="@(e => Element.ImageSizing = Enum.TryParse<ImageSizing>(e.Value?.ToString(), out var z) ? z : ImageSizing.Fit)"
                        style="flex:1;font-size:11.5px;">
                    @foreach (var z in Enum.GetValues<ImageSizing>())
                    {
                        <option value="@z">@z</option>
                    }
                </select></div></div>
        </div>
    }

    @* ── Chart editor (when element kind is Chart) ──────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Chart)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Gráfico</span><span class="count">@Element.ChartSeries.Count</span></div>
            <div class="prop-row">
                <div class="p-label">Tipo</div>
                <div class="p-editor">
                    <select value="@Element.ChartKind"
                            @onchange="@(e => Element.ChartKind = Enum.TryParse<ChartKind>(e.Value?.ToString(), out var k) ? k : ChartKind.Bar)"
                            style="flex:1;font-size:11.5px;">
                        @foreach (var k in Enum.GetValues<ChartKind>())
                        {
                            <option value="@k">@k</option>
                        }
                    </select>
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Título</div>
                <div class="p-editor">
                    <input type="text" value="@Element.ChartTitle" placeholder="(sem título)"
                           @onchange="@(e => Element.ChartTitle = e.Value?.ToString() ?? string.Empty)"
                           style="flex:1;font-size:11.5px;" />
                </div>
            </div>
            <div class="prop-row">
                <div class="p-label">Legenda</div>
                <div class="p-editor">
                    <label style="font-size:11px;"><input type="checkbox" checked="@Element.ShowLegend"
                           @onchange="@(e => Element.ShowLegend = (bool)(e.Value ?? false))" /> Mostrar</label>
                </div>
            </div>
            <div style="padding:6px 10px;">
                @foreach (var (s, i) in Element.ChartSeries.Select((s, i) => (s, i)).ToArray())
                {
                    <div style="border:1px solid var(--border-soft);padding:6px;margin-bottom:6px;border-radius:var(--r-2);background:var(--bg-panel);">
                        <div style="display:flex;align-items:center;gap:4px;margin-bottom:4px;">
                            <span style="font-size:10.5px;color:var(--text-tertiary);flex:1;">Série @(i + 1)</span>
                            <button class="icon-btn" type="button" title="Remover"
                                    @onclick="@(() => Element.ChartSeries.Remove(s))"
                                    style="width:18px;height:18px;color:var(--danger);">×</button>
                        </div>
                        <input type="text" value="@s.Name" placeholder="Nome da série"
                               @onchange="@(e => s.Name = e.Value?.ToString() ?? string.Empty)"
                               style="width:100%;font-size:11px;margin-bottom:4px;" />
                        <input type="text" value="@s.CategoryExpression" placeholder="Fields.Categoria"
                               @onchange="@(e => s.CategoryExpression = e.Value?.ToString() ?? string.Empty)"
                               style="width:100%;font-family:var(--font-mono);font-size:11px;margin-bottom:4px;" />
                        <input type="text" value="@s.ValueExpression" placeholder="Fields.Valor"
                               @onchange="@(e => s.ValueExpression = e.Value?.ToString() ?? string.Empty)"
                               style="width:100%;font-family:var(--font-mono);font-size:11px;" />
                        <div style="display:flex;align-items:center;gap:6px;margin-top:4px;">
                            <span style="font-size:10.5px;color:var(--text-tertiary);">Cor</span>
                            <input type="color" value="@s.ColorHex"
                                   @onchange="@(e => s.ColorHex = e.Value?.ToString() ?? "#4F46E5")"
                                   style="width:28px;height:18px;cursor:pointer;" />
                        </div>
                        @if (Element.ChartKind == ChartKind.Bubble)
                        {
                            <input type="text" value="@s.SizeExpression" placeholder="Tamanho (Fields.X)"
                                   @onchange="@(e => s.SizeExpression = e.Value?.ToString() ?? string.Empty)"
                                   style="width:100%;font-family:var(--font-mono);font-size:11px;margin-top:4px;" />
                        }
                        @if (Element.ChartKind == ChartKind.Stock)
                        {
                            <input type="text" value="@s.HighExpression" placeholder="Máxima (Fields.High)"
                                   @onchange="@(e => s.HighExpression = e.Value?.ToString() ?? string.Empty)"
                                   style="width:100%;font-family:var(--font-mono);font-size:11px;margin-top:4px;" />
                            <input type="text" value="@s.LowExpression" placeholder="Mínima (Fields.Low)"
                                   @onchange="@(e => s.LowExpression = e.Value?.ToString() ?? string.Empty)"
                                   style="width:100%;font-family:var(--font-mono);font-size:11px;margin-top:4px;" />
                        }
                    </div>
                }
                <button class="btn" type="button" style="font-size:11px;padding:3px 8px;cursor:pointer;border:1px dashed var(--border);background:transparent;color:var(--text-secondary);width:100%;"
                        @onclick="@(() => Element.ChartSeries.Add(new ChartSeriesRule()))">+ Adicionar série</button>
            </div>
        </div>
    }


    @* ── Metadata-driven properties (Line orientation, Shape fill/corner, …) ──────
         Replaces the hand-coded Line/Shape sections: each [PropertyGrid]-annotated property
         renders its type's editor automatically (inherited props included), with an fx toggle
         to bind it to an expression. A new derived element gets all of this for free. *@
    <PropertyGridMetaSection Element="Element" OnEditExpression="@(path => OnOpenExpressionEditor.InvokeAsync(path))" />

    @* ── Barcode editor (symbology / ECC / text strip) ───────────────────────── *@
    @if (Element.Kind is DesignerElementKind.Barcode or DesignerElementKind.QrCode)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Código de barras</span></div>
            @if (Element.Kind == DesignerElementKind.Barcode)
            {
                <div class="prop-row"><div class="p-label">Simbologia</div><div class="p-editor">
                    <select value="@Element.Symbology"
                            @onchange="@(e => Element.Symbology = Enum.TryParse<BarcodeSymbology>(e.Value?.ToString(), out var s) ? s : BarcodeSymbology.Code128)"
                            style="flex:1;font-size:11.5px;">
                        @foreach (var s in Enum.GetValues<BarcodeSymbology>())
                        {
                            @if (s != BarcodeSymbology.QrCode)
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select></div></div>
                <div class="prop-row"><div class="p-label">Texto</div><div class="p-editor">
                    <span class="editor-toggle">
                        <button class="@(Element.BarcodeShowText ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.BarcodeShowText = true)">On</button>
                        <button class="@(!Element.BarcodeShowText ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.BarcodeShowText = false)">Off</button>
                    </span></div></div>
            }
            else
            {
                <div class="prop-row"><div class="p-label">Correção (ECC)</div><div class="p-editor">
                    <select value="@Element.QrEcc"
                            @onchange="@(e => Element.QrEcc = Enum.TryParse<QrEccLevel>(e.Value?.ToString(), out var q) ? q : QrEccLevel.Medium)"
                            style="flex:1;font-size:11.5px;">
                        @foreach (var q in Enum.GetValues<QrEccLevel>())
                        {
                            <option value="@q">@q</option>
                        }
                    </select></div></div>
            }
        </div>
    }

    @* ── Code editor ─────────────────────────────────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Code)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Código</span></div>
            <div class="prop-row"><div class="p-label">Linguagem</div><div class="p-editor">
                <select value="@Element.CodeLang"
                        @onchange="@(e => Element.CodeLang = Enum.TryParse<CodeLanguage>(e.Value?.ToString(), out var l) ? l : CodeLanguage.CSharp)"
                        style="flex:1;font-size:11.5px;">
                    @foreach (var l in Enum.GetValues<CodeLanguage>())
                    {
                        <option value="@l" selected="@(Element.CodeLang == l)">@l</option>
                    }
                </select></div></div>
            <div class="prop-row" style="flex-direction:column;align-items:stretch;gap:4px;">
                <div class="p-label">Fonte</div>
                <textarea value="@Element.CodeSource" placeholder="public static decimal Imposto(decimal v) => v * 0.18m;"
                          @onchange="@(e => Element.CodeSource = e.Value?.ToString() ?? string.Empty)"
                          rows="8" style="width:100%;font-family:var(--font-mono);font-size:11px;resize:vertical;"></textarea></div>
            <div style="font-size:10.5px;opacity:.75;padding:4px 8px;line-height:1.4;">
                ⚠ Executa C# embutido no relatório (pacote Roslyn opt-in). Use apenas com fontes confiáveis.
            </div>
        </div>
    }

    @* ── Subreport editor ────────────────────────────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Subreport)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Sub-relatório</span></div>
            <div class="prop-row"><div class="p-label">Report ID</div><div class="p-editor">
                <input type="text" value="@Element.SubreportReportId" placeholder="nome no registro de reports"
                       @onchange="@(e => Element.SubreportReportId = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Dados</div><div class="p-editor">
                <input type="text" value="@Element.SubreportDataExpression" placeholder="Fields.Itens (expressão no pai)"
                       @onchange="@(e => Element.SubreportDataExpression = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
            <div class="prop-row" style="flex-direction:column;align-items:stretch;gap:4px;">
                <div class="p-label">Parâmetros (nome=expressão)</div>
                <textarea value="@Element.SubreportParametersText" placeholder="dataInicio=Parameters.De&#10;clienteId=Fields.id"
                          @onchange="@(e => Element.SubreportParametersText = e.Value?.ToString() ?? string.Empty)"
                          rows="4" style="width:100%;font-family:var(--font-mono);font-size:11px;resize:vertical;"></textarea></div>
        </div>
    }

    @* ── Tablix editor ──────────────────────────────────────────────────────── *@
    @if (Element.Kind == DesignerElementKind.Tablix)
    {
        <div class="prop-section">
            <div class="prop-section-head"><Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" /><span>Tabela</span><span class="count">@Element.TablixColumns.Count</span></div>
            <div class="prop-row"><div class="p-label">Fonte</div><div class="p-editor">
                <input type="text" value="@Element.TablixDataSet" placeholder="(fonte primária)"
                       @onchange="@(e => Element.TablixDataSet = e.Value?.ToString() ?? string.Empty)"
                       style="flex:1;font-size:11.5px;" /></div></div>
            <div class="prop-row"><div class="p-label">Matrix</div><div class="p-editor">
                <label style="font-size:11px;"><input type="checkbox" checked="@Element.TablixIsMatrix"
                       @onchange="@(e => Element.SetTablixMatrix((bool)(e.Value ?? false)))" /> Crosstab (grupos linha × coluna)</label></div></div>
            @if (Element.TablixIsMatrix)
            {
                <div class="prop-row"><div class="p-label">Grupos linha</div><div class="p-editor">
                    <textarea value="@Element.TablixRowGroupsText" placeholder="Fields.Regiao&#10;Fields.Cidade (aninhar: 1 por linha)" rows="2"
                              @onchange="@(e => Element.TablixRowGroupsText = e.Value?.ToString() ?? string.Empty)"
                              style="flex:1;font-family:var(--font-mono);font-size:11.5px;resize:vertical;"></textarea></div></div>
                <div class="prop-row"><div class="p-label">Grupos coluna</div><div class="p-editor">
                    <textarea value="@Element.TablixColumnGroupsText" placeholder="Fields.Ano&#10;Fields.Mes (aninhar: 1 por linha)" rows="2"
                              @onchange="@(e => Element.TablixColumnGroupsText = e.Value?.ToString() ?? string.Empty)"
                              style="flex:1;font-family:var(--font-mono);font-size:11.5px;resize:vertical;"></textarea></div></div>
                <div class="prop-row"><div class="p-label">Canto</div><div class="p-editor">
                    <input type="text" value="@Element.TablixCorner" placeholder="(rótulo do canto)"
                           @onchange="@(e => Element.TablixCorner = e.Value?.ToString() ?? string.Empty)"
                           style="flex:1;font-size:11.5px;" /></div></div>
                <div class="prop-row"><div class="p-label">Célula (Σ)</div><div class="p-editor">
                    <input type="text" value="@Element.TablixCellExpr" placeholder="Fields.Total"
                           @onchange="@(e => Element.TablixCellExpr = e.Value?.ToString() ?? string.Empty)"
                           style="flex:1;font-family:var(--font-mono);font-size:11.5px;" /></div></div>
            }
            else
            {
            <div style="padding:6px 10px;">
                @foreach (var (col, i) in Element.TablixColumns.Select((c, i) => (c, i)).ToArray())
                {
                    <div style="border:1px solid var(--border-soft);padding:6px;margin-bottom:6px;border-radius:var(--r-2);background:var(--bg-panel);">
                        <div style="display:flex;align-items:center;gap:4px;margin-bottom:4px;">
                            <span style="flex:1;font-size:10.5px;color:var(--text-tertiary);">Coluna @(i + 1)</span>
                            <button class="icon-btn" type="button" title="Remover"
                                    @onclick="@(() => Element.RemoveTablixColumn(i))"
                                    style="width:18px;height:18px;color:var(--danger);">×</button>
                        </div>
                        <input type="text" value="@col.Header" placeholder="Cabeçalho"
                               @onchange="@(e => Element.SetTablixColumn(i, header: e.Value?.ToString()))"
                               style="width:100%;font-size:11px;margin-bottom:4px;" />
                        <input type="text" value="@col.Expression" placeholder="Fields.X"
                               @onchange="@(e => Element.SetTablixColumn(i, expression: e.Value?.ToString()))"
                               style="width:100%;font-family:var(--font-mono);font-size:11px;margin-bottom:4px;" />
                        <div style="display:flex;align-items:center;gap:6px;">
                            <span style="font-size:10.5px;color:var(--text-tertiary);white-space:nowrap;">Largura</span>
                            <input type="number" min="0" step="0.1"
                                   value="@(col.Width > 0 ? col.Width.ToString(System.Globalization.CultureInfo.InvariantCulture) : "")"
                                   placeholder="auto"
                                   @onchange="@(e => Element.SetTablixColumn(i, width: ParseWeight(e.Value?.ToString())))"
                                   title="Peso relativo da coluna (ex.: 2 = o dobro de uma coluna de peso 1). Vazio/0 = divide igualmente."
                                   style="width:64px;font-size:11px;" />
                            <span style="font-size:10px;color:var(--text-tertiary);">peso (0 = igual)</span>
                        </div>
                    </div>
                }
                <button class="btn" type="button" style="font-size:11px;padding:3px 8px;cursor:pointer;border:1px dashed var(--border);background:transparent;color:var(--text-secondary);width:100%;"
                        @onclick="@(() => Element.AddTablixColumn())">+ Adicionar coluna</button>
            </div>
            }
        </div>
    }

    @* ── Conditional Formatting ──────────────────────────────────────────────── *@
    <div class="prop-section">
        <div class="prop-section-head">
            <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
            <span>Conditional Format</span>
            <span class="count">@Element.ConditionalFormats.Count</span>
        </div>
        <div style="padding:6px 10px;">
            @foreach (var (rule, i) in Element.ConditionalFormats.Select((r, i) => (r, i)).ToArray())
            {
                <div style="border:1px solid var(--border-soft);padding:6px;margin-bottom:6px;border-radius:var(--r-2);background:var(--bg-panel);">
                    <div style="display:flex;align-items:center;gap:4px;margin-bottom:4px;">
                        <span style="font-size:10.5px;color:var(--text-tertiary);flex:1;">Regra @(i + 1)</span>
                        <button class="icon-btn" type="button" title="Remover"
                                @onclick="@(() => Element.ConditionalFormats.Remove(rule))"
                                style="width:18px;height:18px;color:var(--danger);">×</button>
                    </div>
                    <input type="text" value="@rule.Condition" placeholder="Fields.X > 100"
                           @onchange="@(e => rule.Condition = e.Value?.ToString() ?? string.Empty)"
                           style="width:100%;font-family:var(--font-mono);font-size:11px;margin-bottom:4px;" />
                    <div style="display:flex;align-items:center;gap:6px;font-size:11px;">
                        <label><input type="checkbox" checked="@rule.Bold"
                                      @onchange="@(e => rule.Bold = (bool)(e.Value ?? false))" /> Bold</label>
                        <label><input type="checkbox" checked="@rule.Italic"
                                      @onchange="@(e => rule.Italic = (bool)(e.Value ?? false))" /> Italic</label>
                        <input type="color" value="@(rule.ForeColor is null ? "#000000" : ColorHex(rule.ForeColor.Value))"
                               @onchange="@(e => rule.ForeColor = TryColor(e.Value?.ToString()))"
                               title="Fore" style="width:24px;height:16px;cursor:pointer;" />
                        <input type="color" value="@(rule.BackColor is null ? "#ffffff" : ColorHex(rule.BackColor.Value))"
                               @onchange="@(e => rule.BackColor = TryColor(e.Value?.ToString()))"
                               title="Back" style="width:24px;height:16px;cursor:pointer;" />
                    </div>
                </div>
            }
            <button class="btn" type="button" style="font-size:11px;padding:3px 8px;cursor:pointer;border:1px dashed var(--border);background:transparent;color:var(--text-secondary);width:100%;"
                    @onclick="AddConditionalFormat">+ Adicionar regra</button>
        </div>
    </div>

    @* ── RDL Interactions: Bookmark + DocumentMap + Action ──────────────────── *@
    <div class="prop-section">
        <div class="prop-section-head">
            <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
            <span>Interactions</span>
            <span class="count">@InteractionCount(Element)</span>
        </div>
        <div class="prop-row">
            <div class="p-label" title="RDL <Bookmark>: âncora que outras ações Action.BookmarkLink podem referenciar.">Bookmark</div>
            <div class="p-editor">
                <input type="text" value="@(Element.Bookmark ?? "")" placeholder="ex: linha-totais"
                       @onchange="@(e => Element.Bookmark = AsNullable(e.Value?.ToString()))"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label" title="RDL <Label>: rótulo do elemento no Document Map / sumário lateral.">Doc Map</div>
            <div class="p-editor">
                <input type="text" value="@(Element.DocumentMapLabel ?? "")" placeholder="ex: Total geral"
                       @onchange="@(e => Element.DocumentMapLabel = AsNullable(e.Value?.ToString()))"
                       style="flex:1;font-size:11.5px;" />
            </div>
        </div>
        <div class="prop-row">
            <div class="p-label" title="RDL <Action>: tipo de ação ao clicar no elemento (PDF link, navegação interna, drill-through).">Action</div>
            <div class="p-editor">
                <span class="editor-toggle">
                    <button class="@(!Element.HasAction ? "is-on" : null)" type="button"
                            title="Sem ação" @onclick="@(() => Element.HasAction = false)">—</button>
                    <button class="@(Element.HasAction && Element.ActionKind == ActionKind.Hyperlink ? "is-on" : null)" type="button"
                            title="Hyperlink" @onclick="@(() => { Element.HasAction = true; Element.ActionKind = ActionKind.Hyperlink; })">🔗</button>
                    <button class="@(Element.HasAction && Element.ActionKind == ActionKind.BookmarkLink ? "is-on" : null)" type="button"
                            title="Pular para bookmark" @onclick="@(() => { Element.HasAction = true; Element.ActionKind = ActionKind.BookmarkLink; })">⤵</button>
                    <button class="@(Element.HasAction && Element.ActionKind == ActionKind.DrillthroughReport ? "is-on" : null)" type="button"
                            title="Drillthrough (abrir outro relatório)" @onclick="@(() => { Element.HasAction = true; Element.ActionKind = ActionKind.DrillthroughReport; })">⤴</button>
                </span>
            </div>
        </div>
        @if (Element.HasAction)
        {
            if (Element.ActionKind == ActionKind.Hyperlink)
            {
                <div class="prop-row">
                    <div class="p-label">URL</div>
                    <div class="p-editor">
                        <input type="text" value="@(Element.Hyperlink ?? "")"
                               placeholder="https://example.com/{Fields.Id}"
                               @onchange="@(e => Element.Hyperlink = AsNullable(e.Value?.ToString()))"
                               style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                    </div>
                </div>
            }
            else if (Element.ActionKind == ActionKind.BookmarkLink)
            {
                <div class="prop-row">
                    <div class="p-label">Bookmark ID</div>
                    <div class="p-editor">
                        <input type="text" value="@(Element.BookmarkLinkId ?? "")"
                               placeholder="id-do-bookmark-alvo"
                               @onchange="@(e => Element.BookmarkLinkId = AsNullable(e.Value?.ToString()))"
                               style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                    </div>
                </div>
            }
            else if (Element.ActionKind == ActionKind.DrillthroughReport)
            {
                <div class="prop-row">
                    <div class="p-label">Report</div>
                    <div class="p-editor">
                        <input type="text" value="@(Element.DrillthroughReportName ?? "")"
                               placeholder="NomeDoRelatorioAlvo"
                               @onchange="@(e => Element.DrillthroughReportName = AsNullable(e.Value?.ToString()))"
                               style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
                    </div>
                </div>
                <div style="padding:6px 10px;border-top:1px dashed var(--border-soft);">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                        <span style="font-size:10.5px;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:0.04em;">Parâmetros</span>
                        <button class="btn" type="button"
                                @onclick="AddDrillthroughParameter"
                                style="font-size:10.5px;padding:1px 6px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text-secondary);">+ Adicionar</button>
                    </div>
                    @foreach (var (param, i) in Element.DrillthroughParameters.Select((p, i) => (p, i)).ToArray())
                    {
                        <div style="display:flex;align-items:center;gap:4px;margin-bottom:3px;">
                            <input type="text" value="@param.Name" placeholder="Nome"
                                   @onchange="@(e => param.Name = e.Value?.ToString() ?? string.Empty)"
                                   style="width:70px;font-family:var(--font-mono);font-size:11px;" />
                            <span style="color:var(--text-tertiary);">=</span>
                            <input type="text" value="@param.Value" placeholder="{Fields.X}"
                                   @onchange="@(e => param.Value = e.Value?.ToString() ?? string.Empty)"
                                   style="flex:1;font-family:var(--font-mono);font-size:11px;" />
                            <label title="Omit: não passa o parâmetro" style="font-size:10.5px;">
                                <input type="checkbox" checked="@param.Omit"
                                       @onchange="@(e => param.Omit = (bool)(e.Value ?? false))" />∅</label>
                            <button class="icon-btn" type="button" title="Remover"
                                    @onclick="@(() => Element.DrillthroughParameters.Remove(param))"
                                    style="width:18px;height:18px;color:var(--danger);">×</button>
                        </div>
                    }
                    @if (Element.DrillthroughParameters.Count == 0)
                    {
                        <div style="font-size:10.5px;color:var(--text-tertiary);font-style:italic;padding:2px 0;">
                            Nenhum parâmetro. Clique em + para adicionar.
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* ── RDL Visibility (ToggleItem drill-down) ─────────────────────────────── *@
    <div class="prop-section">
        <div class="prop-section-head">
            <Icon Name="chevron-down" Size="12" CssClass="chev icon icon-12" />
            <span>Drill-down</span>
            <span class="count">@(string.IsNullOrEmpty(Element.ToggleItemId) ? 0 : (Element.InitiallyHidden ? 2 : 1))</span>
        </div>
        <div class="prop-row">
            <div class="p-label" title="RDL <ToggleItem>: bookmark do elemento que controla o expand/collapse deste.">Toggle by</div>
            <div class="p-editor">
                <input type="text" value="@(Element.ToggleItemId ?? "")" placeholder="bookmark-do-elemento-toggle"
                       @onchange="@(e => Element.ToggleItemId = AsNullable(e.Value?.ToString()))"
                       style="flex:1;font-family:var(--font-mono);font-size:11.5px;" />
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Element.ToggleItemId))
        {
            <div class="prop-row">
                <div class="p-label" title="RDL <Hidden>: inicia colapsado, o usuário expande clicando no toggle.">Start hidden</div>
                <div class="p-editor">
                    <span class="editor-toggle">
                        <button class="@(Element.InitiallyHidden ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.InitiallyHidden = true)">On</button>
                        <button class="@(!Element.InitiallyHidden ? "is-on" : null)" type="button"
                                @onclick="@(() => Element.InitiallyHidden = false)">Off</button>
                    </span>
                </div>
            </div>
        }
    </div>

    <div class="prop-section">
        <div class="prop-section-head"><Icon Name="chevron-right" Size="12" CssClass="chev icon icon-12" /><span>Misc</span><span class="count">4</span></div>
    </div>

    <!-- legacy heading kept for backward-compatible tests (Identidade/Posição/Tipografia). -->
    <div style="display:none">Identidade · Posição (mm) · Tipografia</div>
}

@code {
    [Parameter] public ElementViewModel? Element { get; set; }
    [Parameter] public string BandLabel { get; set; } = "Detail";
    /// <summary>Asks the host to open the rich expression editor. A null argument edits the element's
    /// primary Text/Expression (legacy "Data" fx); a non-null property path edits that property's
    /// expression binding (the metadata grid's per-property "fx").</summary>
    [Parameter] public EventCallback<string?> OnOpenExpressionEditor { get; set; }

    private Task OpenExpressionEditor() => OnOpenExpressionEditor.InvokeAsync(null);

    private ElementViewModel? _subscribed;

    private bool IsBound => Element is not null
        && Element.Kind is DesignerElementKind.TextBox or DesignerElementKind.Barcode
        && !string.IsNullOrEmpty(Element.Expression);

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(_subscribed, Element))
        {
            if (_subscribed is not null) _subscribed.Changed -= StateHasChanged;
            _subscribed = Element;
            if (_subscribed is not null) _subscribed.Changed += StateHasChanged;
        }
    }

    public void Dispose()
    {
        if (_subscribed is not null) _subscribed.Changed -= StateHasChanged;
    }

    private RenderFragment Row(string label, string value, Action<string?> setter) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "prop-row");
        {
            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", "p-label");
            builder.AddContent(4, label);
            builder.CloseElement();

            builder.OpenElement(5, "div");
            builder.AddAttribute(6, "class", "p-editor");
            {
                builder.OpenElement(7, "input");
                builder.AddAttribute(8, "type", "number");
                builder.AddAttribute(9, "step", "0.1");
                builder.AddAttribute(10, "value", value);
                builder.AddAttribute(11, "style", "flex:1;font-family:var(--font-mono);font-size:11.5px;");
                builder.AddAttribute(12, "onchange", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<ChangeEventArgs>(
                    this, e => setter(e.Value?.ToString())));
                builder.CloseElement();

                builder.OpenElement(13, "span");
                builder.AddAttribute(14, "class", "p-unit");
                builder.AddContent(15, "mm");
                builder.CloseElement();
            }
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private static string ToMm(Unit u) => u.ToMm().ToString("F1", CultureInfo.InvariantCulture);

    private static string ColorHex(Color c)
    {
        var h = c.ToHex();
        return h.Length == 9 ? "#" + h[3..] : h; // strip alpha for HTML color picker
    }

    private static string KindIcon(ElementViewModel e) => e.Kind switch
    {
        DesignerElementKind.Label     => "hash",
        DesignerElementKind.TextBox   => "type",
        DesignerElementKind.Line      => "minus",
        DesignerElementKind.Rectangle => "square",
        DesignerElementKind.Ellipse   => "circle",
        DesignerElementKind.Image     => "image",
        DesignerElementKind.Barcode   => "barcode",
        _ => "type",
    };

    private static Unit? ParseMm(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        return double.TryParse(raw, NumberStyles.Any, CultureInfo.InvariantCulture, out var mm)
            ? Unit.FromMm(mm) : null;
    }

    // ─── Image upload ──────────────────────────────────────────────────────────
    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        if (Element is null || e.File is null) return;
        using var ms = new MemoryStream();
        await using var src = e.File.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
        await src.CopyToAsync(ms);
        Element.InlineImageData = ms.ToArray();
    }

    /// <summary>Parses a Tablix column-weight input. <c>type="number"</c> always posts an
    /// invariant (dot-decimal) string; blank or non-positive means "equal share" (weight 0).</summary>
    private static double ParseWeight(string? raw)
        => double.TryParse(raw, System.Globalization.NumberStyles.Any,
               System.Globalization.CultureInfo.InvariantCulture, out var w) && w > 0 ? w : 0;

    // ─── Conditional formats ───────────────────────────────────────────────────
    private void AddConditionalFormat()
    {
        Element?.ConditionalFormats.Add(new ConditionalFormatRule());
    }

    private static Color? TryColor(string? hex)
    {
        if (string.IsNullOrEmpty(hex)) return null;
        try { return Color.FromHex(hex); } catch { return null; }
    }

    // ─── RDL interactions (Bookmark / DocumentMap / Action) ────────────────────

    /// <summary>Returns the empty string as null so the PropertyGrid round-trips
    /// "cleared" inputs back to a clean null on the VM — matching how the serializer
    /// treats empty + null identically.</summary>
    private static string? AsNullable(string? v) => string.IsNullOrWhiteSpace(v) ? null : v;

    /// <summary>How many interaction fields are set — used as the section badge count.</summary>
    private static int InteractionCount(ElementViewModel e)
    {
        int n = 0;
        if (!string.IsNullOrWhiteSpace(e.Bookmark)) n++;
        if (!string.IsNullOrWhiteSpace(e.DocumentMapLabel)) n++;
        if (e.HasAction) n++;
        return n;
    }

    private void AddDrillthroughParameter()
    {
        Element?.DrillthroughParameters.Add(new DrillthroughParameterRule { Name = "Param", Value = "" });
    }
}
