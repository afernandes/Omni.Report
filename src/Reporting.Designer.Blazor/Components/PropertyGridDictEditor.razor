@using Reporting.Common
@using Reporting.Designer.Blazor.Services
@using Reporting.Designer.Blazor.ViewModels

@*
    Generic editor for an EquatableDictionary<string,string> property (key → value/expression): one row
    per entry with add/remove. The rows live in LOCAL component state with a stable @key, so editing a
    key never reorders or drops rows — an EquatableDictionary enumerates in hash order, so re-deriving the
    rows from it on every keystroke would re-shuffle them and send edits to the wrong row, and a row whose
    key is momentarily empty (while retyping) or collides with another would vanish on the round-trip. New
    entries get a unique default key. The immutable dict is rebuilt and pushed back on every change; empty
    keys stay visible as rows but aren't persisted (you can't have an unnamed parameter).
*@

<div style="display:flex;flex-direction:column;gap:3px;width:100%;">
    @foreach (var row in _rows)
    {
        var r = row;
        <div @key="r.Id" style="display:flex;align-items:center;gap:3px;">
            <input type="text" value="@r.Key" placeholder="chave" title="Chave"
                   @onchange="@(e => EditKey(r, e.Value?.ToString() ?? string.Empty))"
                   style="flex:0 0 36%;font-family:var(--font-mono);font-size:11px;" />
            <span style="color:var(--text-tertiary);">=</span>
            <input type="text" value="@r.Value" placeholder="valor / expressão" title="Valor"
                   @onchange="@(e => EditValue(r, e.Value?.ToString() ?? string.Empty))"
                   style="flex:1;font-family:var(--font-mono);font-size:11px;" />
            <button class="icon-btn" type="button" title="Remover" @onclick="@(() => RemoveRow(r))"
                    style="width:18px;height:18px;color:var(--text-tertiary);flex:0 0 auto;">×</button>
        </div>
    }
    <button class="icon-btn" type="button" @onclick="AddRow"
            style="align-self:flex-start;font-size:10.5px;padding:2px 8px;">+ Adicionar</button>
</div>

@code {
    [Parameter, EditorRequired] public ElementViewModel Element { get; set; } = default!;
    [Parameter, EditorRequired] public PropertyGridDescriptor Descriptor { get; set; } = default!;

    private sealed class Row
    {
        public string Id { get; } = Guid.NewGuid().ToString("N");
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private readonly List<Row> _rows = new();
    private ElementViewModel? _seededElement;
    private string? _seededPath;

    // Seed the local rows once per (element, descriptor) — NOT on our own commits, which keep the same
    // Element reference. That keeps the visible order stable and independent of the dict's hash order.
    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_seededElement, Element) && _seededPath == Descriptor.Path)
        {
            return;
        }
        _seededElement = Element;
        _seededPath = Descriptor.Path;
        _rows.Clear();
        var entries = Descriptor.Get(Element.ToElement()) as IEnumerable<KeyValuePair<string, string>>;
        if (entries is not null)
        {
            foreach (var kv in entries)
            {
                _rows.Add(new Row { Key = kv.Key, Value = kv.Value });
            }
        }
    }

    private void EditKey(Row row, string key)
    {
        row.Key = key;
        Commit();
    }

    private void EditValue(Row row, string val)
    {
        row.Value = val;
        Commit();
    }

    private void AddRow()
    {
        var key = "param";
        var n = 1;
        while (_rows.Any(r => r.Key == key))
        {
            key = $"param{++n}";
        }
        _rows.Add(new Row { Key = key });
        Commit();
    }

    private void RemoveRow(Row row)
    {
        _rows.Remove(row);
        Commit();
    }

    private void Commit()
    {
        var dict = new Dictionary<string, string>(StringComparer.Ordinal);
        foreach (var r in _rows)
        {
            if (!string.IsNullOrEmpty(r.Key))
            {
                dict[r.Key] = r.Value; // empty keys stay as rows but aren't persisted; last wins on a transient collision
            }
        }
        Element.ApplyMetaSet(Descriptor, new EquatableDictionary<string, string>(dict));
    }
}
