@using System.Collections
@using System.Globalization
@using Reporting.Designer.Blazor.Services
@using Reporting.Designer.Blazor.ViewModels
@using Reporting.Styling

@*
    Generic editor for an EquatableArray<T> property. Each item T is itself rendered from its
    [PropertyGrid]-annotated fields (recursive metadata) — so a new element with a list of annotated
    records gets add/remove + per-field editing for free, with no hand-coded list UI. Items live in
    LOCAL component state with a stable @key, so add/remove never re-binds an input to the wrong row.
*@

<div style="display:flex;flex-direction:column;gap:3px;width:100%;">
    @foreach (var row in _rows)
    {
        var r = row;
        var item = r.Item;
        <div @key="r.Id" style="display:flex;align-items:center;gap:3px;flex-wrap:wrap;">
            @foreach (var f in ItemFields)
            {
                var field = f;
                var val = field.Get(item);
                switch (field.Editor)
                {
                    case "color-hex":
                        var hex = val as string is { Length: > 0 } s ? s : "#000000";
                        <input type="color" value="@ColorHexUtil.ToRgbHexString(hex)" title="@field.Label"
                               @onchange="@(e => EditField(r, field, ColorHexUtil.MergeHexAlpha(hex, e.Value?.ToString())))"
                               style="width:28px;height:18px;padding:0;cursor:pointer;flex:0 0 auto;" />
                        break;

                    case "color-picker":
                        var col = val as Color?;
                        <span title="@field.Label"
                              style="width:14px;height:14px;border-radius:2px;border:1px solid var(--border);flex:0 0 auto;background:@(col is { } c ? c.ToHex() : "transparent");@(col is null ? "border-style:dashed;" : null)"></span>
                        <input type="color" value="@ColorHexUtil.ToRgbHex(col ?? Color.Black)" title="@field.Label"
                               @onchange="@(e => EditField(r, field, ColorHexUtil.WithRgb(col ?? Color.Black, e.Value?.ToString())))"
                               style="width:28px;height:18px;padding:0;cursor:pointer;flex:0 0 auto;" />
                        @if (col is not null && field.IsNullable)
                        {
                            <button class="icon-btn" type="button" title="Limpar (paleta automática)" @onclick="@(() => EditField(r, field, null))"
                                    style="width:16px;height:16px;color:var(--text-tertiary);flex:0 0 auto;">×</button>
                        }
                        break;

                    case "enum":
                        <select title="@field.Label" style="flex:1;font-size:11px;"
                                @onchange="@(e => EditField(r, field, Enum.Parse(EnumType(field), e.Value?.ToString() ?? string.Empty, ignoreCase: true)))">
                            @foreach (var v in Enum.GetValues(EnumType(field)))
                            {
                                <option value="@v" selected="@(Equals(val, v))">@v</option>
                            }
                        </select>
                        break;

                    case "number":
                        <input type="number" step="0.1" title="@field.Label"
                               value="@Convert.ToString(val, CultureInfo.InvariantCulture)"
                               @onchange="@(e => EditField(r, field, ConvertNumber(field, e.Value)))"
                               style="width:54px;font-size:11px;" />
                        break;

                    default:
                        <input type="text" placeholder="@field.Label" title="@field.Label"
                               value="@Convert.ToString(val)"
                               @onchange="@(e => EditField(r, field, e.Value?.ToString()))"
                               style="flex:1;font-family:var(--font-mono);font-size:11px;" />
                        break;
                }
            }
            <button class="icon-btn" type="button" title="Remover" @onclick="@(() => RemoveRow(r))"
                    style="width:18px;height:18px;color:var(--text-tertiary);flex:0 0 auto;">×</button>
        </div>
    }
    <button class="icon-btn" type="button" @onclick="AddRow"
            style="align-self:flex-start;font-size:10.5px;padding:2px 8px;">+ Adicionar</button>
</div>

@code {
    [Parameter, EditorRequired] public ElementViewModel Element { get; set; } = default!;
    [Parameter, EditorRequired] public PropertyGridDescriptor Descriptor { get; set; } = default!;

    private sealed class Row
    {
        public string Id { get; } = Guid.NewGuid().ToString("N");
        public object Item { get; set; } = default!;
    }

    private readonly List<Row> _rows = new();
    private ElementViewModel? _seededElement;
    private string? _seededPath;

    private Type ItemType => Descriptor.Type.GetGenericArguments()[0];
    private IReadOnlyList<PropertyGridDescriptor> ItemFields => PropertyGridDescriptors.For(ItemType);

    // Seed local rows once per (element, descriptor) — NOT on our own commits (same Element reference) —
    // so add/remove never re-derives identity-less items and re-binds an input to a shifted row.
    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_seededElement, Element) && _seededPath == Descriptor.Path)
        {
            return;
        }
        _seededElement = Element;
        _seededPath = Descriptor.Path;
        _rows.Clear();
        if (Descriptor.Get(Element.ToElement()) is IEnumerable items)
        {
            foreach (var it in items)
            {
                _rows.Add(new Row { Item = it });
            }
        }
    }

    private static Type EnumType(PropertyGridDescriptor d) => Nullable.GetUnderlyingType(d.Type) ?? d.Type;

    // Coerce the input string to the field's numeric type before the setter — PropertyInfo.SetValue throws
    // on a string→double/int, so passing the raw string would break editing a numeric list-item field.
    private static object ConvertNumber(PropertyGridDescriptor d, object? value)
    {
        var parsed = double.TryParse(Convert.ToString(value, CultureInfo.InvariantCulture),
            NumberStyles.Any, CultureInfo.InvariantCulture, out var x) ? x : 0;
        return Convert.ChangeType(parsed, Nullable.GetUnderlyingType(d.Type) ?? d.Type, CultureInfo.InvariantCulture);
    }

    private void EditField(Row row, PropertyGridDescriptor field, object? value)
    {
        row.Item = field.Set(row.Item, value);
        Commit();
    }

    private void RemoveRow(Row row)
    {
        _rows.Remove(row);
        Commit();
    }

    private void AddRow()
    {
        _rows.Add(new Row { Item = CreateDefaultItem(ItemType) });
        Commit();
    }

    /// <summary>Rebuilds the immutable EquatableArray&lt;T&gt; from the working rows and pushes it back
    /// through the metadata setter (which re-hydrates the element, opaque-advanced included).</summary>
    private void Commit()
    {
        var typed = (IList)Activator.CreateInstance(typeof(List<>).MakeGenericType(ItemType))!;
        foreach (var r in _rows)
        {
            typed.Add(r.Item);
        }
        var newArray = Activator.CreateInstance(Descriptor.Type, typed)!;
        Element.ApplyMetaSet(Descriptor, newArray);
    }

    /// <summary>Creates a fresh list item by invoking its primary constructor with defaulted args
    /// (empty string / default struct / null) — the user then fills the fields in.</summary>
    private static object CreateDefaultItem(Type itemType)
    {
        var ctor = itemType.GetConstructors().OrderByDescending(c => c.GetParameters().Length).First();
        var args = ctor.GetParameters().Select(p =>
            p.ParameterType == typeof(string) ? string.Empty
            : p.ParameterType.IsValueType ? Activator.CreateInstance(p.ParameterType)
            : null).ToArray();
        return ctor.Invoke(args);
    }
}
