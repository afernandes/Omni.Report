<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Reporting.Rendering.Skia</RootNamespace>
    <AssemblyName>Reporting.Rendering.Skia</AssemblyName>
    <Description>OmniReport — SkiaSharp implementation of IRenderingContext. Produces PNG/SVG/PDF output from layout primitives.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Reporting.Core\Reporting.Core.csproj" />
    <ProjectReference Include="..\Reporting.Rendering\Reporting.Rendering.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SkiaSharp" />
    <!-- O metapacote base do SkiaSharp traz os nativos de Windows/macOS, mas NÃO o de
         Linux. Sem isto, consumidores e o CI no Linux quebram com
         DllNotFoundException: 'libSkiaSharp'. A variante .NoDependencies depende do
         fontconfig do sistema (libfontconfig1) — instalado no job de CI. -->
    <PackageReference Include="SkiaSharp.NativeAssets.Linux.NoDependencies" />
  </ItemGroup>

</Project>
